[
  {
    "id": "US-108",
    "title": "Search posts",
    "acceptance_criteria": [
      {
        "id": "AC-108-1",
        "title": "Search filters posts by keyword",
        "narrative": "Given I am on the search page\nWhen I type a keyword in the search input\nThen I should see posts matching that keyword\n",
        "given": [
          {
            "visit": "/search"
          }
        ],
        "when": [
          {
            "fill": {
              "selector": "[data-test=search-input]",
              "value": "svelte"
            }
          }
        ],
        "then": [
          {
            "shouldExist": {
              "selector": "[data-test=search-results] [data-test=post-card]"
            }
          }
        ]
      },
      {
        "id": "AC-108-2",
        "title": "Empty search results show message",
        "narrative": "Given I am on the search page\nWhen I search for a term with no matches\nThen I should see an empty results message\n",
        "given": [
          {
            "visit": "/search"
          }
        ],
        "when": [
          {
            "fill": {
              "selector": "[data-test=search-input]",
              "value": "xyznonexistent123"
            }
          }
        ],
        "then": [
          {
            "shouldExist": {
              "selector": "[data-test=no-results]"
            }
          }
        ]
      }
    ]
  },
