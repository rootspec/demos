  {
    "id": "US-110",
    "title": "Filter posts by tag",
    "acceptance_criteria": [
      {
        "id": "AC-110-1",
        "title": "Clicking a tag filters posts",
        "narrative": "Given I am on the explore page\nWhen I click on a trending tag\nThen I should see only posts with that tag\n",
