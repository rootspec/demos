---
import Layout from '../layouts/Layout.astro';
import Hero from '../sections/Hero.astro';
import MetaBanner from '../sections/MetaBanner.astro';
import Problem from '../sections/Problem.astro';
import HowItWorks from '../sections/HowItWorks.astro';
import HierarchyExplorer from '../sections/HierarchyExplorer';
import SpecWizard from '../sections/SpecWizard';
import Comparison from '../sections/Comparison';
import CTA from '../sections/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="RootSpec - Specification-Driven Development">
  <Hero />
  <MetaBanner />
  <Problem />
  <HowItWorks />
  <HierarchyExplorer client:load />
  <SpecWizard client:load />
  <Comparison client:load />
  <CTA />
  <Footer />
</Layout>

<style>
  main {
    width: 100%;
    max-width: 100%;
  }
</style>