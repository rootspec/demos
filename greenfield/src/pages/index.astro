---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import MetaBanner from '../sections/MetaBanner.astro';
import Hero from '../sections/Hero.astro';
import Problem from '../sections/Problem.astro';
import HowItWorks from '../sections/HowItWorks.astro';
import HierarchyExplorer from '../sections/HierarchyExplorer.tsx';
import SpecWizard from '../sections/SpecWizard.tsx';
import Comparison from '../sections/Comparison.tsx';
import CTA from '../sections/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />
  <main data-test="main-content" class="relative">
    <MetaBanner />
    <Hero />
    <Problem />
    <HowItWorks />
    <section class="py-16 bg-gray-50 dark:bg-gray-800" data-test="interactive-section">
      <div class="container mx-auto px-4">
        <HierarchyExplorer client:load />
      </div>
    </section>
    <section class="py-16" data-test="wizard-section">
      <div class="container mx-auto px-4">
        <SpecWizard client:load />
      </div>
    </section>
    <section class="py-16 bg-gray-50 dark:bg-gray-800" data-test="comparison-section">
      <div class="container mx-auto px-4">
        <Comparison client:load />
      </div>
    </section>
    <CTA />
  </main>
  <Footer />
</Layout>