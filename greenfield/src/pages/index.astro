---
import Layout from '../layouts/Layout.astro';
import MetaBanner from '../components/MetaBanner.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import ProblemSection from '../components/ProblemSection.astro';
import WorkflowSection from '../components/WorkflowSection.astro';
import HierarchySection from '../components/HierarchySection.astro';
import ComparisonSection from '../components/ComparisonSection';
import SpecWizard from '../components/SpecWizard';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
---
<Layout>
  <MetaBanner />
  <Header />
  <main>
    <HeroSection />
    <ProblemSection />
    <WorkflowSection />
    <HierarchySection />
    <ComparisonSection client:load />
    <SpecWizard client:load />
    <CTASection />
  </main>
  <Footer />
</Layout>
