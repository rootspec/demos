---
import Layout from '../layouts/Layout.astro';
---

<Layout title="RootSpec - Specification Methodology">
  <main>
    <!-- Meta Banner -->
    <div class="meta-banner bg-blue-50 border-b border-blue-200 p-4">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm text-blue-700">
          This site was built using RootSpec. View the
          <a href="https://github.com/anthropics/demos/blob/main/greenfield/SEED.md"
             class="underline hover:no-underline"
             data-test="meta-link-spec">seed file</a>
          and
          <a href="https://github.com/anthropics/demos/tree/main/greenfield/rootspec"
             class="underline hover:no-underline"
             data-test="meta-link-spec">specification</a>
        </p>
      </div>
    </div>

    <!-- Hero Section -->
    <section class="hero py-16 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl font-bold mb-6">RootSpec</h1>
        <p class="text-xl text-gray-600 mb-8">
          Specification methodology for building software that works
        </p>
      </div>
    </section>

    <!-- Comparison Section -->
    <section class="comparison py-16 px-4 bg-gray-50" data-test="comparison-section">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">Before & After</h2>

        <div class="text-center mb-8">
          <button
            id="comparison-toggle"
            class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700"
            data-test="comparison-toggle">
            Toggle View
          </button>
        </div>

        <div class="comparison-panels grid md:grid-cols-2 gap-8">
          <!-- Without RootSpec -->
          <div class="panel" data-test="comparison-without">
            <h3 class="text-xl font-semibold mb-4 text-red-600">Without RootSpec</h3>
            <div class="bg-white p-6 rounded-lg border">
              <p class="text-gray-700 mb-4">
                "Build a task management app with vague requirements and unclear acceptance criteria."
              </p>
              <ul class="text-sm text-gray-600 space-y-2">
                <li>• Ambiguous requirements</li>
                <li>• No clear success metrics</li>
                <li>• Manual testing approach</li>
                <li>• Unclear user journeys</li>
              </ul>
            </div>
          </div>

          <!-- With RootSpec -->
          <div class="panel transition-all duration-300" data-test="comparison-with">
            <h3 class="text-xl font-semibold mb-4 text-green-600">With RootSpec</h3>
            <div class="bg-white p-6 rounded-lg border" data-test="comparison-panel">
              <div data-test="comparison-content">
                <p class="text-gray-700 mb-4">
                  "Build a task management app with structured hierarchy and testable acceptance criteria."
                </p>
                <ul class="text-sm text-gray-600 space-y-2">
                  <li>• Clear, testable requirements</li>
                  <li>• Automated validation</li>
                  <li>• Structured user journeys</li>
                  <li>• Measurable success criteria</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Getting Started -->
    <section class="getting-started py-16 px-4" data-test="getting-started">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-8">Get Started</h2>
        <div class="bg-gray-900 text-green-400 p-6 rounded-lg text-left font-mono text-sm">
          <div class="mb-2"># Initialize RootSpec in your project</div>
          <div class="mb-4">npx @rootspec/cli rs-init</div>

          <div class="mb-2"># Create your specification</div>
          <div class="mb-4">npx @rootspec/cli rs-spec</div>

          <div class="mb-2"># Implement and validate</div>
          <div>npx @rootspec/cli rs-impl && npx @rootspec/cli rs-validate</div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white py-8 px-4" data-test="footer">
      <div class="max-w-4xl mx-auto text-center">
        <p class="mb-4">
          Learn more about RootSpec methodology
        </p>
        <a
          href="https://github.com/anthropics/demos"
          class="inline-flex items-center text-blue-400 hover:text-blue-300"
          data-test="github-link">
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          View on GitHub
        </a>
      </div>
    </footer>
  </main>
</Layout>

<script>
  // Comparison toggle functionality
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('comparison-toggle');
    const panel = document.querySelector('[data-test="comparison-panel"]');

    if (toggle && panel) {
      toggle.addEventListener('click', () => {
        panel.classList.toggle('with-rootspec');

        // Update content when toggled
        if (panel.classList.contains('with-rootspec')) {
          // Enhanced view showing more structure
          const content = panel.querySelector('[data-test="comparison-content"]');
          if (content) {
            content.innerHTML = `
              <p class="text-gray-700 mb-4">
                "Build a task management app with structured hierarchy and testable acceptance criteria."
              </p>
              <ul class="text-sm text-gray-600 space-y-2">
                <li>• Clear, testable requirements</li>
                <li>• Automated validation</li>
                <li>• Structured user journeys</li>
                <li>• Measurable success criteria</li>
                <li>• Hierarchical specification structure</li>
                <li>• Test-driven development approach</li>
              </ul>
            `;
          }
        } else {
          // Reset to original view
          const content = panel.querySelector('[data-test="comparison-content"]');
          if (content) {
            content.innerHTML = `
              <p class="text-gray-700 mb-4">
                "Build a task management app with structured hierarchy and testable acceptance criteria."
              </p>
              <ul class="text-sm text-gray-600 space-y-2">
                <li>• Clear, testable requirements</li>
                <li>• Automated validation</li>
                <li>• Structured user journeys</li>
                <li>• Measurable success criteria</li>
              </ul>
            `;
          }
        }
      });
    }
  });
</script>