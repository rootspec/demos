---
import Layout from '../layouts/Layout.astro';
import MetaBanner from '../components/MetaBanner.astro';
import HeroSection from '../components/HeroSection.astro';
import ProblemSection from '../components/ProblemSection.astro';
import WorkflowSection from '../components/WorkflowSection.astro';
import HierarchyExplorer from '../components/HierarchyExplorer.astro';
import SpecWizard from '../components/SpecWizard.astro';
import ComparisonSection from '../components/ComparisonSection.astro';
import CTASection from '../components/CTASection.astro';
---
<Layout>
  <MetaBanner />
  <HeroSection />
  <ProblemSection />
  <WorkflowSection />
  <HierarchyExplorer />

  <section style="padding:5rem 1.5rem;">
    <div style="max-width:900px;margin:0 auto;">
      <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;color:var(--accent);text-transform:uppercase;margin-bottom:0.75rem;">Try it</p>
      <h2 style="font-size:clamp(1.75rem,4vw,2.75rem);font-weight:700;margin-bottom:1rem;letter-spacing:-0.02em;">
        Build your first spec
      </h2>
      <p style="color:var(--muted);font-size:1.0625rem;line-height:1.65;max-width:580px;margin-bottom:2.5rem;">
        Walk through the three core inputs and see a skeleton RootSpec output.
      </p>
      <SpecWizard />
    </div>
  </section>

  <ComparisonSection />
  <CTASection />
</Layout>
