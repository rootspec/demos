---
import Layout from '../layouts/Layout.astro';
import MetaBanner from '../components/MetaBanner.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import ProblemSection from '../components/ProblemSection.astro';
import WorkflowSection from '../components/WorkflowSection.astro';
import HierarchySection from '../components/HierarchySection.astro';
import MethodologyDiagram from '../components/MethodologyDiagram.astro';
import ComparisonSection from '../components/ComparisonSection.tsx';
import SpecWizard from '../components/SpecWizard.tsx';
import CTASection from '../components/CTASection.astro';
---

<Layout title="RootSpec — Spec-Driven AI Development">
  <MetaBanner />
  <Header />
  <main>
    <HeroSection />
    <ProblemSection />
    <WorkflowSection />
    <HierarchySection />
    <MethodologyDiagram />
    <ComparisonSection client:load />
    <SpecWizard client:load />
    <CTASection />
  </main>
  <footer class="py-8 px-4 text-center border-t border-white/10">
    <p class="text-[var(--text-secondary)] text-sm font-mono">
      RootSpec v7.3.0 · Built with Claude Code
    </p>
  </footer>
</Layout>
