---
import Layout from '../layouts/Layout.astro';
import MetaBanner from '../sections/MetaBanner.astro';
import Hero from '../sections/Hero.astro';
import Problem from '../sections/Problem.astro';
import HowItWorks from '../sections/HowItWorks.astro';
import HierarchyExplorer from '../sections/HierarchyExplorer.tsx';
import SpecWizard from '../sections/SpecWizard.tsx';
import Comparison from '../sections/Comparison.tsx';
import CTA from '../sections/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <main>
    <MetaBanner />
    <Hero />
    <Problem />
    <HowItWorks />
    <HierarchyExplorer client:load />
    <SpecWizard client:load />
    <Comparison client:load />
    <CTA />
  </main>
  <Footer />
</Layout>

<style>
  main {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
</style>