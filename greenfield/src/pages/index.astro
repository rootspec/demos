---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../sections/Hero.astro';
import MetaBanner from '../sections/MetaBanner.astro';
import HierarchyExplorer from '../sections/HierarchyExplorer';
import SpecWizard from '../sections/SpecWizard';
import Comparison from '../sections/Comparison';
import CTA from '../sections/CTA.astro';
---

<Layout title="RootSpec - Structured Software Specifications">
  <Header />

  <main>
    <!-- Hero section with version badge and tagline -->
    <Hero />

    <!-- Meta banner explaining site generation -->
    <MetaBanner />

    <!-- Interactive hierarchy explorer -->
    <section class="py-24 bg-gray-50 dark:bg-gray-800">
      <div class="max-w-6xl mx-auto px-4">
        <HierarchyExplorer client:visible />
      </div>
    </section>

    <!-- Spec creation wizard -->
    <section class="py-24">
      <div class="max-w-4xl mx-auto px-4">
        <SpecWizard client:visible />
      </div>
    </section>

    <!-- Before/after comparison -->
    <section class="py-24 bg-gray-50 dark:bg-gray-800">
      <div class="max-w-6xl mx-auto px-4">
        <Comparison client:visible />
      </div>
    </section>

    <!-- Call to action section -->
    <CTA />
  </main>

  <Footer />
</Layout>