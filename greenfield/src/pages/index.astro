---
import Layout from '../layouts/Layout.astro';
import MetaBanner from '../components/MetaBanner.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import ProblemSection from '../components/ProblemSection.astro';
import HierarchySection from '../components/HierarchySection.astro';
import SpecWizardSection from '../components/SpecWizardSection.astro';
import WorkflowSection from '../components/WorkflowSection.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="RootSpec — Spec-first. AI-ready. Actually works.">
  <div data-test="page-root">
    <MetaBanner />
    <Header />
    <main>
      <HeroSection />
      <ProblemSection />
      <HierarchySection />
      <SpecWizardSection />
      <WorkflowSection />
      <CTASection />
    </main>
    <footer class="py-8 px-4 border-t border-slate-200 dark:border-slate-700 text-center text-sm text-slate-500 dark:text-slate-400">
      <p>Built with RootSpec v7.2.4 &mdash; the spec-first methodology for AI-powered development.</p>
    </footer>
  </div>
</Layout>
