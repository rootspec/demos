---
import Layout from '../layouts/Layout.astro';
import MetaBanner from '../components/MetaBanner.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import ProblemSection from '../components/ProblemSection.astro';
import WorkflowSection from '../components/WorkflowSection.astro';
import HierarchySection from '../components/HierarchySection.astro';
import ComparisonSection from '../components/ComparisonSection.astro';
import SpecWizardSection from '../components/SpecWizardSection.astro';
import CTASection from '../components/CTASection.astro';
---

<Layout title="RootSpec — Spec-driven AI Development">
  <MetaBanner />
  <Header />
  <main>
    <HeroSection />
    <ProblemSection />
    <WorkflowSection />
    <HierarchySection />
    <ComparisonSection />
    <SpecWizardSection />
    <CTASection />
  </main>
  <footer data-test="footer" class="py-12 px-4 border-t border-[var(--border-color)]">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-[var(--text-secondary)]">
      <div data-test="footer-attribution" class="text-center sm:text-left">
        Built by <span class="text-[var(--text-primary)] font-medium">Claude</span> (Anthropic) using RootSpec methodology ·
        <span id="build-date"></span>
      </div>
      <div class="flex items-center gap-4">
        <a href="https://github.com/rootspec/rootspec" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--text-primary)] transition-colors">
          GitHub
        </a>
        <a href="#" class="hover:text-[var(--text-primary)] transition-colors">
          MIT License
        </a>
      </div>
    </div>
  </footer>
  <script>
    const el = document.getElementById('build-date');
    if (el) {
      el.textContent = new Date().getFullYear().toString();
    }
  </script>
</Layout>
