---
import Layout from '../layouts/Layout.astro';
import MetaBanner from '../components/MetaBanner.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import ProblemSection from '../components/ProblemSection.astro';
import ComparisonSection from '../components/ComparisonSection';
import HierarchyExplorer from '../components/HierarchyExplorer';
import SpecWizard from '../components/SpecWizard';
import Footer from '../components/Footer.astro';
---

<Layout title="RootSpec — Spec-Driven Development">
  <MetaBanner />
  <Header />
  <main>
    <HeroSection />
    <ProblemSection />
    <ComparisonSection client:load />
    <HierarchyExplorer client:load />
    <SpecWizard client:load />
  </main>
  <Footer />
</Layout>
