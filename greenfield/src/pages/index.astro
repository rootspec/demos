---
import Layout from '../layouts/Layout.astro';
import ThemeToggle from '../components/ThemeToggle';
import HierarchyExplorer from '../components/HierarchyExplorer';
import SpecWizard from '../components/SpecWizard';
import BeforeAfter from '../components/BeforeAfter';

const VERSION = '7.1.2';
const BUILD_DATE = new Date().toISOString().split('T')[0];
---

<Layout title="RootSpec — Spec-Driven Development">
  <!-- Meta Banner -->
  <div data-test="meta-banner" style="background: #1e3a5f; color: #93c5fd; padding: 8px 20px; font-size: 0.8rem; display: flex; gap: 16px; align-items: center; justify-content: center; flex-wrap: wrap; border-bottom: 1px solid #2563eb;">
    <span>Built by the <strong>RootSpec pipeline</strong> — spec-driven, test-first, autonomous.</span>
    <a data-test="meta-banner-seed-link" href="https://github.com/rootspec/demos/blob/main/greenfield/SEED.md" target="_blank" rel="noopener" style="color: #60a5fa; text-decoration: underline;">View SEED.md</a>
    <a data-test="meta-banner-spec-link" href="https://github.com/rootspec/demos/tree/main/greenfield/rootspec" target="_blank" rel="noopener" style="color: #60a5fa; text-decoration: underline;">View Spec</a>
  </div>

  <!-- Header / Nav -->
  <header style="height: var(--nav-height); border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 24px; background: var(--bg); position: sticky; top: 0; z-index: 50;">
    <span style="font-weight: 800; font-size: 1rem; color: var(--accent);">RootSpec</span>
    <ThemeToggle client:load />
  </header>

  <!-- Hero Section -->
  <section style="padding: 80px 24px 64px; text-align: center; max-width: var(--max-width); margin: 0 auto;">
    <div style="display: flex; justify-content: center; margin-bottom: 16px;">
      <span data-test="version-badge" style="background: var(--card-bg); border: 1px solid var(--border); color: var(--accent); padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 700;">
        v{VERSION}
      </span>
    </div>
    <h1 data-test="hero-tagline" style="font-size: clamp(2rem, 6vw, 3.5rem); font-weight: 900; line-height: 1.1; margin: 0 0 20px; color: var(--text);">
      Ship software that<br /><span style="color: var(--accent);">matches its spec.</span>
    </h1>
    <p data-test="hero-subhead" style="font-size: 1.1rem; color: var(--text-muted); max-width: 560px; margin: 0 auto 32px; line-height: 1.6;">
      RootSpec is a five-level specification methodology for autonomous, test-driven software development — from product idea to passing tests.
    </p>
    <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
      <a href="#how-it-works" style="background: var(--accent); color: #fff; padding: 10px 24px; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 0.9rem;">See How It Works</a>
      <a href="#cta" data-test="github-link" href="https://github.com/rootspec/rootspec" target="_blank" rel="noopener" style="background: var(--card-bg); border: 1px solid var(--border); color: var(--text); padding: 10px 24px; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 0.9rem;">GitHub →</a>
    </div>
  </section>

  <!-- Problem Section -->
  <section data-test="problem-section" style="padding: 64px 24px; background: var(--bg-secondary); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div style="max-width: var(--max-width); margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; text-align: center; margin: 0 0 16px; color: var(--text);">The Spec Gap Problem</h2>
      <p style="text-align: center; color: var(--text-muted); max-width: 540px; margin: 0 auto 40px; line-height: 1.6;">
        Most teams ship software that diverges from what was planned. Here's why.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px;">
        {[
          { title: 'Specs are prose', desc: 'Written in Slack, Notion, or Jira comments — not structured enough for automation or testing.' },
          { title: 'No shared language', desc: 'Designers, PMs, and engineers interpret "requirements" differently.' },
          { title: 'Untestable criteria', desc: 'Acceptance criteria like "it should feel fast" can\'t become automated tests.' },
          { title: 'Drift over time', desc: 'Code diverges from spec as requirements evolve, with no traceability.' },
        ].map(item => (
          <div style="background: var(--card-bg); border: 1px solid var(--border); border-radius: 10px; padding: 20px;">
            <div style="width: 8px; height: 8px; background: #ef4444; border-radius: 50%; margin-bottom: 12px;"></div>
            <h3 style="font-size: 0.95rem; font-weight: 700; margin: 0 0 8px; color: var(--text);">{item.title}</h3>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin: 0; line-height: 1.5;">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section id="how-it-works" data-test="how-it-works-section" style="padding: 64px 24px;">
    <div style="max-width: var(--max-width); margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; text-align: center; margin: 0 0 12px; color: var(--text);">How It Works</h2>
      <p style="text-align: center; color: var(--text-muted); max-width: 500px; margin: 0 auto 40px; line-height: 1.6;">
        Four skills guide you from idea to tested, deployed software.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px;">
        {[
          { cmd: 'rs-init', desc: 'Bootstraps the project structure, spec directory, and test infrastructure.' },
          { cmd: 'rs-spec', desc: 'Generates all five levels of spec from a product seed file.' },
          { cmd: 'rs-impl', desc: 'Implements features from user stories with test-driven code generation.' },
          { cmd: 'rs-validate', desc: 'Runs the full test suite and generates a spec compliance report.' },
        ].map((skill, i) => (
          <div style="background: var(--card-bg); border: 1px solid var(--border); border-radius: 10px; padding: 20px; border-top: 3px solid var(--accent);">
            <div style="font-size: 0.7rem; color: var(--text-muted); margin-bottom: 6px;">Step {i + 1}</div>
            <code style="font-size: 1.05rem; font-weight: 800; color: var(--accent);">/{skill.cmd}</code>
            <p style="font-size: 0.85rem; color: var(--text-muted); margin: 8px 0 0; line-height: 1.5;">{skill.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hierarchy Explorer Section -->
  <section style="padding: 64px 24px; background: var(--bg-secondary); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div style="max-width: 760px; margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; text-align: center; margin: 0 0 12px; color: var(--text);">The Five-Level Hierarchy</h2>
      <p style="text-align: center; color: var(--text-muted); max-width: 500px; margin: 0 auto 32px; line-height: 1.6;">
        Click any level to explore what it contains.
      </p>
      <HierarchyExplorer client:load />
    </div>
  </section>

  <!-- Before/After Comparison Section -->
  <section style="padding: 64px 24px;">
    <div style="max-width: 760px; margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; text-align: center; margin: 0 0 12px; color: var(--text);">Vague vs. Structured Specs</h2>
      <p style="text-align: center; color: var(--text-muted); max-width: 500px; margin: 0 auto 32px; line-height: 1.6;">
        Toggle to see how RootSpec transforms informal requirements into testable user stories.
      </p>
      <BeforeAfter client:load />
    </div>
  </section>

  <!-- Spec Wizard Section -->
  <section style="padding: 64px 24px; background: var(--bg-secondary); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div style="max-width: 680px; margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; text-align: center; margin: 0 0 12px; color: var(--text);">Try the Spec Wizard</h2>
      <p style="text-align: center; color: var(--text-muted); max-width: 500px; margin: 0 auto 32px; line-height: 1.6;">
        Answer three questions and see a skeleton RootSpec output for your product.
      </p>
      <SpecWizard client:load />
    </div>
  </section>

  <!-- CTA Section -->
  <section id="cta" data-test="cta-section" style="padding: 80px 24px; text-align: center;">
    <div style="max-width: 600px; margin: 0 auto;">
      <h2 style="font-size: 2rem; font-weight: 900; margin: 0 0 16px; color: var(--text);">Open Source & Free</h2>
      <p style="color: var(--text-muted); margin: 0 0 32px; line-height: 1.6; font-size: 1rem;">
        RootSpec is open source and free to use. Star the repo, read the docs, or run <code style="background: var(--card-bg); padding: 2px 6px; border-radius: 4px; color: var(--accent);">/rs-init</code> in your next project.
      </p>
      <a
        data-test="github-link"
        href="https://github.com/rootspec/rootspec"
        target="_blank"
        rel="noopener"
        style="display: inline-block; background: var(--text); color: var(--bg); padding: 12px 32px; border-radius: 8px; font-weight: 800; text-decoration: none; font-size: 1rem; transition: opacity 200ms ease;"
      >
        ★ Star on GitHub
      </a>
    </div>
  </section>

  <!-- Footer -->
  <footer data-test="footer" style="border-top: 1px solid var(--border); padding: 24px; text-align: center; background: var(--bg-secondary);">
    <p data-test="footer-attribution" style="color: var(--text-muted); font-size: 0.8rem; margin: 0;">
      Built with <strong>RootSpec</strong> — spec-driven development methodology.
      <span style="margin-left: 8px;">Build date: <time>{BUILD_DATE}</time></span>
    </p>
  </footer>
</Layout>
