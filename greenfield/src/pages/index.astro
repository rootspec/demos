---
import Layout from '../layouts/Layout.astro';
import MetaBanner from '../sections/MetaBanner.astro';
import Hero from '../sections/Hero.astro';
import HierarchyExplorer from '../sections/HierarchyExplorer.tsx';
import SpecWizard from '../sections/SpecWizard.tsx';
import Comparison from '../sections/Comparison.tsx';
import CTA from '../sections/CTA.astro';
---

<Layout title="RootSpec - Build Better Software Specifications">
  <MetaBanner />
  <Hero />

  <section id="hierarchy-explorer">
    <HierarchyExplorer client:load />
  </section>

  <section id="spec-wizard">
    <SpecWizard client:load />
  </section>

  <section id="comparison">
    <Comparison client:load />
  </section>

  <CTA />
</Layout>

<style>
  section {
    margin: var(--spacing-3xl) 0;
  }

  #hierarchy-explorer, #spec-wizard, #comparison {
    scroll-margin-top: 80px; /* Account for any fixed header */
  }
</style>