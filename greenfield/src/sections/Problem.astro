---
const painPoints = [
  {
    title: 'Spec drift',
    description: 'Requirements documents diverge from implementation within weeks. Nobody notices until it\'s too late.',
  },
  {
    title: 'Philosophy-implementation gap',
    description: 'The "why" behind a product lives in founders\' heads and degrades at every handoff. AI accelerates this degradation.',
  },
  {
    title: 'Unreliable AI output',
    description: 'AI tools generate code confidently but have no way to validate alignment with intent. More code, same drift.',
  },
  {
    title: 'Dead documentation',
    description: 'Specs written once, shared once, read never. No living connection to what gets built.',
  },
];
---

<section id="problem" data-test="problem-section" class="py-16 sm:py-24 px-4 sm:px-6 bg-[var(--color-bg-alt)]">
  <div class="max-w-content mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">The problem</h2>
    <p class="mt-4 text-lg text-[var(--color-text-secondary)] max-w-2xl">
      AI has knowledge but not wisdom. Humans supply philosophy; AI executes implementation. Without a bridge, intent degrades at every step.
    </p>
    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {painPoints.map((point) => (
        <div data-test="pain-point" class="p-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)]">
          <h3 class="font-semibold text-lg">{point.title}</h3>
          <p class="mt-2 text-[var(--color-text-secondary)] leading-relaxed">{point.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
