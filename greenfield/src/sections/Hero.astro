---
// Hero section with value proposition (US-002)
---

<section data-test="hero" class="py-16 md:py-24 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <!-- Version Badge -->
      <div class="inline-flex items-center px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm font-medium mb-6">
        <span data-test="version-badge">v7.0.3</span>
        <span class="mx-2">•</span>
        <span>Latest Release</span>
      </div>

      <!-- Main Heading -->
      <h1 data-test="hero-tagline" class="text-4xl md:text-6xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
        Product Specifications<br>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600">
          That Actually Work
        </span>
      </h1>

      <!-- Description -->
      <div data-test="hero-description" class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 mb-8 leading-relaxed">
        <p class="mb-4">
          Turn a 100-line product description into a fully working application with RootSpec's structured methodology.
        </p>
        <p class="text-lg">
          No more spec drift. No more philosophy-implementation gaps. Just clear, testable requirements that guide your entire development process.
        </p>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href="#wizard"
          class="inline-flex items-center px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-xl hover:from-blue-700 hover:to-purple-700 transition-all duration-200 font-semibold text-lg shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
        >
          Try the Spec Wizard
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>

        <a
          href="#explorer"
          class="inline-flex items-center px-8 py-4 border-2 border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-xl hover:border-gray-400 dark:hover:border-gray-500 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all duration-200 font-semibold text-lg"
        >
          Explore the Methodology
        </a>
      </div>

      <!-- Stats -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8 max-w-3xl mx-auto">
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-blue-600 dark:text-blue-400 mb-2">5</div>
          <div class="text-gray-600 dark:text-gray-300">Structured Levels</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-purple-600 dark:text-purple-400 mb-2">4</div>
          <div class="text-gray-600 dark:text-gray-300">Core Skills</div>
        </div>
        <div class="text-center">
          <div class="text-3xl md:text-4xl font-bold text-green-600 dark:text-green-400 mb-2">100%</div>
          <div class="text-gray-600 dark:text-gray-300">Test Coverage</div>
        </div>
      </div>
    </div>
  </div>
</section>