---
import { ROOTSPEC_VERSION } from '../data/config';
---

<section class="bg-gradient-to-b from-blue-50 to-white dark:from-gray-900 dark:to-gray-800 py-24">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <!-- Version badge -->
    <div class="mb-6">
      <span
        data-test="version-badge"
        class="inline-block px-3 py-1 text-sm bg-blue-100 dark:bg-blue-900 text-blue-800 dark:text-blue-200 rounded-full"
      >
        v{ROOTSPEC_VERSION}
      </span>
    </div>

    <!-- Main heading -->
    <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
      RootSpec
    </h1>

    <!-- Tagline -->
    <p
      data-test="hero-tagline"
      class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 mb-6 font-medium"
    >
      Turn product ideas into structured specifications
    </p>

    <!-- Explanation -->
    <p
      data-test="hero-explanation"
      class="text-lg text-gray-700 dark:text-gray-400 mb-12 max-w-2xl mx-auto leading-relaxed"
    >
      RootSpec provides a five-level methodology for creating comprehensive software specifications.
      From high-level philosophy to detailed implementation stories, build clarity into every project.
    </p>

    <!-- Quick navigation buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="#hierarchy-explorer"
        class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors font-medium"
      >
        Explore the Framework
      </a>
      <a
        href="#spec-wizard"
        class="px-6 py-3 border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 rounded-lg transition-colors font-medium"
      >
        Try the Wizard
      </a>
    </div>
  </div>
</section>