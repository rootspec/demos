---
import { SEED_URL, SPEC_URL } from '../data/config';
---

<section class="bg-purple-50 dark:bg-purple-900/20 py-12 border-y border-purple-200 dark:border-purple-800">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <div
      data-test="meta-banner"
      class="prose prose-purple dark:prose-invert mx-auto"
    >
      <p class="text-lg text-purple-700 dark:text-purple-300 mb-6">
        ✨ This entire marketing site was <strong>generated from a ~100-line product description</strong> using RootSpec methodology.
        <strong>No manual code, no design mockups</strong> — just structured specification turned into working software.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          data-test="view-spec-link"
          href={SPEC_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg transition-colors text-sm font-medium"
        >
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
          </svg>
          View Full Specification
        </a>

        <a
          data-test="view-seed-link"
          href={SEED_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-4 py-2 border border-purple-300 dark:border-purple-600 hover:bg-purple-100 dark:hover:bg-purple-900/30 text-purple-700 dark:text-purple-300 rounded-lg transition-colors text-sm font-medium"
        >
          <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M4 3a2 2 0 100 4h12a2 2 0 100-4H4z" />
            <path fill-rule="evenodd" d="M3 8h14v7a2 2 0 01-2 2H5a2 2 0 01-2-2V8zm5 3a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1z" clip-rule="evenodd" />
          </svg>
          View Original SEED
        </a>
      </div>
    </div>
  </div>
</section>