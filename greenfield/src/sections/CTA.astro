---
// Call-to-action section with getting started information
---

<section data-test="cta-section" class="cta">
  <div class="cta-content">
    <div class="cta-header">
      <h2>Ready to Get Started?</h2>
      <p>Transform your next project with RootSpec's structured methodology</p>
    </div>

    <div data-test="getting-started" class="getting-started">
      <h3>Getting Started is Simple</h3>

      <div class="steps-grid">
        <div class="step">
          <div class="step-number">1</div>
          <h4>Install RootSpec</h4>
          <p>Add RootSpec to your project with one command</p>
          <code class="code-snippet">npx skills add rootspec/rootspec</code>
        </div>

        <div class="step">
          <div class="step-number">2</div>
          <h4>Initialize</h4>
          <p>Set up your project structure and framework</p>
          <code class="code-snippet">/rs-init</code>
        </div>

        <div class="step">
          <div class="step-number">3</div>
          <h4>Create Spec</h4>
          <p>Build your specification through guided interviews</p>
          <code class="code-snippet">/rs-spec</code>
        </div>

        <div class="step">
          <div class="step-number">4</div>
          <h4>Implement</h4>
          <p>Turn your spec into working code with tests</p>
          <code class="code-snippet">/rs-impl</code>
        </div>
      </div>

      <div class="resources">
        <h3>Learn More</h3>
        <div class="resource-links">
          <a href="https://github.com/rootspec/rootspec" data-test="github-link" class="resource-link primary">
            <div class="link-icon">📚</div>
            <div class="link-content">
              <h4>Documentation</h4>
              <p>Complete guides and tutorials</p>
            </div>
          </a>

          <a href="https://github.com/rootspec/rootspec" data-test="documentation-link" class="resource-link secondary">
            <div class="link-icon">💻</div>
            <div class="link-content">
              <h4>GitHub Repository</h4>
              <p>Source code and examples</p>
            </div>
          </a>

          <a href="#spec-wizard" class="resource-link secondary">
            <div class="link-icon">🧙‍♂️</div>
            <div class="link-content">
              <h4>Try the Wizard</h4>
              <p>Generate a spec from your idea</p>
            </div>
          </a>
        </div>
      </div>
    </div>

    <div class="cta-footer">
      <div class="footer-content">
        <div class="community">
          <h4>Join the Community</h4>
          <p>Connect with other developers using RootSpec</p>
          <div class="social-links">
            <a href="#" class="social-link">Discord</a>
            <a href="#" class="social-link">Twitter</a>
            <a href="#" class="social-link">LinkedIn</a>
          </div>
        </div>

        <div class="version-info">
          <h4>Current Version</h4>
          <p>RootSpec v6.2 - Built for modern development teams</p>
          <small>Last updated: March 2026</small>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    background: linear-gradient(135deg, var(--color-primary), #0052a3);
    color: white;
    padding: var(--spacing-3xl) 0;
    position: relative;
    overflow: hidden;
  }

  .cta::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="50" cy="50" r="1" fill="white" opacity="0.1"/></svg>') repeat;
    animation: float 30s linear infinite;
  }

  .cta-content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--spacing-md);
    position: relative;
    z-index: 1;
  }

  .cta-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .cta-header h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 var(--spacing-md) 0;
  }

  .cta-header p {
    font-size: 1.25rem;
    margin: 0;
    opacity: 0.9;
  }

  .getting-started {
    margin-bottom: var(--spacing-3xl);
  }

  .getting-started h3 {
    text-align: center;
    font-size: 2rem;
    font-weight: 600;
    margin: 0 0 var(--spacing-xl) 0;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-3xl);
  }

  .step {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: var(--spacing-xl);
    text-align: center;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: transform 0.3s ease;
  }

  .step:hover {
    transform: translateY(-4px);
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: white;
    color: var(--color-primary);
    border-radius: 50%;
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 var(--spacing-md) 0;
  }

  .step h4 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 var(--spacing-sm) 0;
  }

  .step p {
    margin: 0 0 var(--spacing-md) 0;
    opacity: 0.9;
    line-height: 1.5;
  }

  .code-snippet {
    display: inline-block;
    background: rgba(0, 0, 0, 0.3);
    color: #fbbf24;
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: 6px;
    font-family: var(--font-family-mono);
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.5px;
  }

  .resources {
    text-align: center;
  }

  .resources h3 {
    font-size: 2rem;
    font-weight: 600;
    margin: 0 0 var(--spacing-xl) 0;
  }

  .resource-links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
    max-width: 900px;
    margin: 0 auto;
  }

  .resource-link {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-lg);
    background: rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    text-decoration: none;
    color: white;
    transition: all 0.3s ease;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .resource-link:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .resource-link:focus {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  .resource-link.primary {
    background: rgba(255, 255, 255, 0.2);
  }

  .resource-link.primary:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .link-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .link-content {
    text-align: left;
  }

  .link-content h4 {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 var(--spacing-xs) 0;
  }

  .link-content p {
    margin: 0;
    opacity: 0.8;
    font-size: 0.875rem;
  }

  .cta-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: var(--spacing-xl);
    margin-top: var(--spacing-3xl);
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-xl);
    text-align: center;
  }

  .community h4, .version-info h4 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 var(--spacing-md) 0;
  }

  .community p, .version-info p {
    margin: 0 0 var(--spacing-md) 0;
    opacity: 0.8;
  }

  .social-links {
    display: flex;
    justify-content: center;
    gap: var(--spacing-md);
  }

  .social-link {
    color: white;
    text-decoration: none;
    padding: var(--spacing-sm) var(--spacing-md);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 6px;
    font-size: 0.875rem;
    transition: all 0.3s ease;
  }

  .social-link:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .social-link:focus {
    outline: 2px solid white;
    outline-offset: 2px;
  }

  .version-info small {
    display: block;
    opacity: 0.6;
    font-size: 0.75rem;
  }

  @keyframes float {
    0% { transform: translateX(-50px) translateY(-50px); }
    100% { transform: translateX(50px) translateY(50px); }
  }

  @media (max-width: 768px) {
    .cta-header h2 {
      font-size: 2rem;
    }

    .getting-started h3, .resources h3 {
      font-size: 1.75rem;
    }

    .steps-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .step {
      padding: var(--spacing-lg);
    }

    .resource-links {
      grid-template-columns: 1fr;
    }

    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .social-links {
      flex-wrap: wrap;
    }
  }
</style>