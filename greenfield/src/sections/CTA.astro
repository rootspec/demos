---
// CTA section - getting started path (US-005)
---

<section data-test="cta-section" class="py-16 md:py-24 bg-gradient-to-r from-blue-600 to-purple-600">
  <div class="container mx-auto px-4 text-center">
    <div class="max-w-4xl mx-auto text-white">
      <h2 class="text-3xl md:text-5xl font-bold mb-6">
        Ready to Build Better Software?
      </h2>

      <p class="text-xl md:text-2xl mb-8 opacity-90">
        Join developers using RootSpec to turn ideas into working applications without the usual requirements chaos.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-12">
        <a
          href="https://github.com/rootspec/rootspec#getting-started"
          data-test="getting-started"
          class="inline-flex items-center px-8 py-4 bg-white text-blue-600 rounded-xl hover:bg-gray-50 transition-all duration-200 font-semibold text-lg shadow-lg hover:shadow-xl transform hover:-translate-y-0.5"
          target="_blank"
          rel="noopener noreferrer"
        >
          Get Started Now
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>

        <a
          href="https://github.com/rootspec/rootspec"
          data-test="github-link"
          class="inline-flex items-center px-8 py-4 border-2 border-white/30 text-white rounded-xl hover:border-white/50 hover:bg-white/10 transition-all duration-200 font-semibold text-lg backdrop-blur-sm"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd" />
          </svg>
          View on GitHub
        </a>
      </div>

      <!-- Quick Start Steps -->
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto text-left">
        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6">
          <div class="flex items-center mb-3">
            <span class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center text-sm font-bold mr-3">1</span>
            <h3 class="font-semibold">Install</h3>
          </div>
          <p class="text-white/80 text-sm">
            <code class="bg-black/20 px-2 py-1 rounded">npm install -g @rootspec/cli</code>
          </p>
        </div>

        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6">
          <div class="flex items-center mb-3">
            <span class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center text-sm font-bold mr-3">2</span>
            <h3 class="font-semibold">Initialize</h3>
          </div>
          <p class="text-white/80 text-sm">
            Run <code class="bg-black/20 px-2 py-1 rounded">/rs-init</code> in your project directory
          </p>
        </div>

        <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6">
          <div class="flex items-center mb-3">
            <span class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center text-sm font-bold mr-3">3</span>
            <h3 class="font-semibold">Specify</h3>
          </div>
          <p class="text-white/80 text-sm">
            Use <code class="bg-black/20 px-2 py-1 rounded">/rs-spec</code> to create your specification
          </p>
        </div>
      </div>
    </div>
  </div>
</section>