---
import BeforeAfter from './BeforeAfter.tsx';
---
<section style="padding:5rem 1.5rem;background:var(--color-bg);">
  <div style="max-width:48rem;margin:0 auto;">
    <h2 style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;margin:0 0 0.75rem;color:var(--color-text);">Before &amp; After</h2>
    <p style="font-size:1.05rem;color:var(--color-text-muted);margin:0 0 2rem;line-height:1.65;">See the difference a structured spec makes.</p>
    <BeforeAfter client:load />
  </div>
</section>
