---
const problems = [
  {
    icon: '⚠️',
    title: 'Spec Drift',
    description: 'Your spec document diverges from the code the moment implementation begins. AI agents build what they infer, not what you intended.',
  },
  {
    icon: '🔁',
    title: 'Endless Rework',
    description: 'Without structured specs, AI-generated code needs constant correction. Each cycle costs time and trust in the process.',
  },
  {
    icon: '🧩',
    title: 'Lost Context',
    description: 'Requirements scattered across Slack, Notion, and your head. AI can\'t read your mind — it needs structured input.',
  },
  {
    icon: '📉',
    title: 'No Validation Loop',
    description: 'Teams ship features without a repeatable way to verify that AI output matches what the spec actually described.',
  },
];
---

<section
  data-test="problem-section"
  id="problem"
  class="py-24 px-4"
>
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        The spec problem is real
      </h2>
      <p class="text-lg text-[var(--text-secondary)] max-w-2xl mx-auto">
        AI coding tools are powerful — but without structured specs, they drift.
        Here's what happens when you skip the spec.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {problems.map((p) => (
        <div class="p-6 rounded-xl border border-white/10 bg-[var(--bg-secondary)] hover:border-accent-500/30 transition-colors">
          <div class="text-3xl mb-3">{p.icon}</div>
          <h3 class="text-lg font-semibold mb-2 text-[var(--text-primary)]">{p.title}</h3>
          <p class="text-[var(--text-secondary)] leading-relaxed">{p.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
