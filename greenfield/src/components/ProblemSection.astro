---
const problems = [
  {
    icon: '📉',
    title: 'Spec Drift',
    desc: 'Requirements documents go stale the moment implementation begins. By sprint 3, nobody trusts the spec.',
  },
  {
    icon: '🤖',
    title: 'Unreliable AI Output',
    desc: 'AI has knowledge but not wisdom. Without a validation gate, generated code accumulates decisions nobody made.',
  },
  {
    icon: '🔀',
    title: 'Philosophy-Implementation Gap',
    desc: 'What the product should feel like gets lost in tickets and PRs. Features ship that contradict the original vision.',
  },
  {
    icon: '📄',
    title: 'Google Docs Nobody Reads',
    desc: 'The spec lives in a shared doc. It\'s never updated, never tested, and never enforced. It\'s decoration.',
  },
];
---

<section data-test="problem-section" class="section-spacing" style="background: var(--card);">
  <div class="container-content">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: var(--fg);">The problem with how we specify software</h2>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--muted);">
        Every team has a spec process. Most are broken in the same ways.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {problems.map((p) => (
        <div class="card flex gap-4">
          <span class="text-3xl flex-shrink-0">{p.icon}</span>
          <div>
            <h3 class="font-semibold text-base mb-1" style="color: var(--fg);">{p.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--muted);">{p.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
