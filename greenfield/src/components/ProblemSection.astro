---
const problems = [
  {
    icon: '⚠️',
    title: 'Spec Drift',
    description: 'Requirements evolve but documentation doesn\'t. AI agents implement yesterday\'s spec, not today\'s intent.',
  },
  {
    icon: '🤖',
    title: 'AI Reliability Gap',
    description: 'Without a structured contract, AI coding agents hallucinate features, skip edge cases, and break on updates.',
  },
  {
    icon: '📄',
    title: 'Documentation Failures',
    description: 'Specs live in Google Docs, Notion pages, or heads of engineers — never trusted, always out of date.',
  },
  {
    icon: '🔄',
    title: 'Rework Cycles',
    description: 'Teams ship, then discover misalignment late. Costly rewrites replace features that were "done."',
  },
];
---
<section data-test="problem-section" id="problem" style="padding: 5rem 1.5rem; background-color: var(--color-surface);">
  <div style="max-width: 1100px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h2 style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; margin: 0 0 0.75rem; color: var(--color-text);">
        Sound Familiar?
      </h2>
      <p style="color: var(--color-text-muted); font-size: 1.1rem; max-width: 560px; margin: 0 auto;">
        Every team building with AI faces the same painful patterns.
      </p>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem;">
      {problems.map(p => (
        <div style="
          background: var(--color-bg);
          border: 1px solid var(--color-border);
          border-radius: 0.75rem;
          padding: 1.5rem;
        ">
          <div style="font-size: 1.75rem; margin-bottom: 0.75rem;">{p.icon}</div>
          <h3 style="font-size: 1rem; font-weight: 600; margin: 0 0 0.5rem; color: var(--color-text);">{p.title}</h3>
          <p style="color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.5; margin: 0;">{p.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
