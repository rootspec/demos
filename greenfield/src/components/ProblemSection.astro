---
const painPoints = [
  {
    title: 'Vague prompts, vague results',
    description: 'Without a spec, AI agents guess what you want. Every run is a gamble — sometimes genius, often garbage.',
  },
  {
    title: 'No shared language between human and AI',
    description: 'Developers think in user stories; AI thinks in tokens. The translation is lossy. Requirements get dropped silently.',
  },
  {
    title: 'Tests written after the fact',
    description: 'When tests come last, they test what was built — not what was needed. Bugs ship anyway.',
  },
  {
    title: 'Spec drift kills velocity',
    description: 'The doc says one thing, the code does another. Teams spend more time debugging misalignment than shipping features.',
  },
  {
    title: 'AI makes confident mistakes',
    description: 'LLMs confidently implement the wrong thing. Without a ground truth, nobody catches it until production.',
  },
];
---

<section
  data-test="problem-section"
  id="problem"
  class="py-24 px-4"
>
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">
        Why most AI dev workflows break down
      </h2>
      <p class="text-[var(--text-secondary)] text-lg max-w-2xl mx-auto">
        The problem isn't the AI. It's the missing spec layer between idea and implementation.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {painPoints.map((point) => (
        <div
          data-test="pain-point"
          class="p-6 rounded-xl border border-[var(--border-color)] bg-[var(--bg-secondary)] hover:border-brand-primary/40 transition-colors group"
        >
          <div class="w-10 h-10 rounded-lg bg-red-500/10 border border-red-500/20 flex items-center justify-center mb-4 text-red-400 group-hover:bg-red-500/20 transition-colors">
            ✕
          </div>
          <h3 class="font-semibold text-base mb-2">{point.title}</h3>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">{point.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
