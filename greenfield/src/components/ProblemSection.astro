---
const problems = [
  {
    icon: '🔀',
    title: 'Misaligned teams',
    desc: 'Developers, designers, and stakeholders interpret requirements differently — causing rework and frustration.',
  },
  {
    icon: '🎯',
    title: 'Scope drift',
    desc: 'Without a shared spec, features grow organically. Deadlines slip. Priorities shift. Goals blur.',
  },
  {
    icon: '🧱',
    title: 'Assumption-driven builds',
    desc: 'Engineers fill gaps with guesses. Products ship features nobody asked for and miss the ones that matter.',
  },
];
---
<section
  data-test="problem-section"
  id="problem"
  class="py-20 px-4"
  style="background-color: var(--color-surface);"
>
  <div class="section-container">
    <h2 class="text-3xl font-bold text-center mb-4" style="color: var(--color-text);">
      The cost of building without a spec
    </h2>
    <p class="text-center text-lg mb-12 max-w-2xl mx-auto" style="color: var(--color-text-muted);">
      Most software projects fail not because of bad engineers, but because of unclear requirements.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {problems.map((p) => (
        <div
          class="rounded-xl p-6"
          style="background-color: var(--color-card-bg); border: 1px solid var(--color-card-border);"
        >
          <div class="text-4xl mb-4">{p.icon}</div>
          <h3 class="text-xl font-semibold mb-2" style="color: var(--color-text);">{p.title}</h3>
          <p style="color: var(--color-text-muted);">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
