---
const version = '7.3.1';
---
<section
  data-test="hero"
  style="padding:6rem 1.5rem 5rem;text-align:center;max-width:800px;margin:0 auto;"
>
  <div
    data-test="version-badge"
    style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--surface);border:1px solid var(--border);border-radius:9999px;padding:0.25rem 0.875rem;font-size:0.75rem;font-weight:600;color:var(--accent-light);margin-bottom:1.5rem;"
  >
    v{version}
  </div>

  <h1 style="font-size:clamp(2.5rem,6vw,4.5rem);font-weight:800;line-height:1.08;letter-spacing:-0.03em;margin-bottom:1.25rem;">
    Specification for<br/>
    <span style="color:var(--accent);">the AI Age</span>
  </h1>

  <p style="font-size:1.125rem;color:var(--muted);max-width:560px;margin:0 auto 2.5rem;line-height:1.6;">
    RootSpec is a structured methodology that keeps AI coding agents aligned
    with your product vision — from philosophy to user stories.
  </p>

  <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
    <a
      href="https://github.com/rootspec/demos"
      target="_blank"
      rel="noopener"
      style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--accent);color:#fff;padding:0.75rem 1.5rem;border-radius:0.5rem;font-weight:600;text-decoration:none;"
    >
      Get started on GitHub
    </a>
    <a
      href="#explore"
      style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--surface);border:1px solid var(--border);color:var(--fg);padding:0.75rem 1.5rem;border-radius:0.5rem;font-weight:500;text-decoration:none;"
    >
      Explore the spec
    </a>
  </div>
</section>
