---
import rootspecConfig from '../../.rootspec.json';
const version = rootspecConfig.version;
---

<section id="hero" data-test="hero" style="padding: var(--space-2xl) 1.5rem; background-color: var(--color-bg);">
  <div style="max-width: 780px; margin: 0 auto;">
    <div style="margin-bottom: 1.5rem;">
      <span
        data-test="version-badge"
        style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem; font-weight: 500; background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: 4px; padding: 0.25rem 0.625rem; color: var(--color-text-secondary);"
      >
        v{version}
      </span>
    </div>
    <h1 style="font-family: 'Source Serif 4', Georgia, serif; font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 400; line-height: 1.15; color: var(--color-text-primary); margin-bottom: 1.25rem; letter-spacing: -0.01em;">
      When code and specs can be generated trivially, <em>proof</em> matters more than ever.
    </h1>
    <p style="font-family: 'Source Serif 4', Georgia, serif; font-size: 1.2rem; color: var(--color-text-secondary); line-height: 1.65; margin-bottom: 2rem; max-width: 640px;">
      RootSpec is a specification methodology for software where philosophy guides implementation, never vice versa. Four commands turn a product description into a validated, running application.
    </p>
    <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;">
      <a
        href="#wizard"
        style="background-color: var(--color-accent); color: #fff; padding: 0.65rem 1.4rem; border-radius: 4px; text-decoration: none; font-weight: 500; font-size: 0.9375rem;"
      >
        Spec your idea →
      </a>
      <a
        href="https://github.com/rootspec/rootspec"
        target="_blank"
        rel="noopener noreferrer"
        style="color: var(--color-text-secondary); font-size: 0.9rem; text-decoration: none; border-bottom: 1px solid var(--color-border); padding-bottom: 1px;"
      >
        View on GitHub
      </a>
    </div>
    <div style="margin-top: 2.5rem; display: flex; flex-wrap: wrap; gap: 1rem;">
      {['/rs-init', '/rs-spec', '/rs-impl', '/rs-validate'].map(cmd => (
        <code style="font-family: 'JetBrains Mono', monospace; font-size: 0.8125rem; background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: 3px; padding: 0.25rem 0.5rem; color: var(--color-text-primary);">
          {cmd}
        </code>
      ))}
    </div>
  </div>
</section>
