---
const VERSION = '7.3.7';
---
<section
  data-test="hero"
  class="w-full py-24 px-4 text-center"
  style="background:linear-gradient(135deg,var(--bg) 0%,var(--surface) 100%);"
>
  <div class="max-w-4xl mx-auto">
    <div class="mb-4 flex justify-center">
      <span
        data-test="version-badge"
        class="inline-block px-3 py-1 rounded-full text-xs font-mono font-semibold"
        style="background-color:var(--surface);color:var(--accent);border:1px solid var(--border);"
      >v{VERSION}</span>
    </div>
    <h1
      data-test="hero-heading"
      class="text-4xl md:text-6xl font-bold mb-6 leading-tight"
      style="color:var(--text);"
    >
      Spec first.<br />
      <span style="color:var(--accent);">Build with confidence.</span>
    </h1>
    <p class="text-lg md:text-xl mb-8 max-w-2xl mx-auto" style="color:var(--text-muted);">
      RootSpec is a structured methodology for defining software with AI agents.
      Write the spec, let the agents implement it — deterministically, verifiably, at any scale.
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a
        href="#how-it-works"
        class="px-6 py-3 rounded-lg font-semibold transition-colors"
        style="background-color:var(--accent);color:#ffffff;"
      >
        See How It Works
      </a>
      <a
        href="#spec-wizard"
        class="px-6 py-3 rounded-lg font-semibold transition-colors border"
        style="background-color:var(--bg);color:var(--text);border-color:var(--border);"
      >
        Try the Wizard
      </a>
    </div>
  </div>
</section>
