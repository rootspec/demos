---
import { readFileSync } from 'fs';
import { join } from 'path';

let version = '7.5.0';
try {
  const raw = readFileSync(join(process.cwd(), '.rootspec.json'), 'utf-8');
  const parsed = JSON.parse(raw);
  version = parsed.version || version;
} catch {
  // fallback
}
---

<section
  data-test="hero-section"
  style="padding: 5rem 1.5rem 4rem; max-width: 72rem; margin: 0 auto;"
>
  <div style="max-width: 48rem;">
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
      <span
        data-test="version-badge"
        style="font-family: 'Courier New', monospace; font-size: 0.75rem; background-color: var(--color-bg-surface); color: var(--color-text-code); border: 1px solid var(--color-border); padding: 0.2rem 0.6rem; border-radius: 3px;"
      >
        v{version}
      </span>
    </div>

    <h1
      style="font-family: Georgia, serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 400; line-height: 1.15; letter-spacing: -0.02em; color: var(--color-text-primary); margin-bottom: 1.5rem;"
    >
      RootSpec
    </h1>

    <p
      style="font-family: Georgia, serif; font-size: clamp(1.125rem, 2.5vw, 1.375rem); color: var(--color-text-secondary); line-height: 1.6; max-width: 36rem; margin-bottom: 2rem;"
    >
      A specification methodology where philosophy guides implementation, never vice versa.
      AI generates. Validation proves.
    </p>

    <p style="font-family: system-ui, sans-serif; font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6;">
      When code and specs can be generated trivially, the real value is validation and proof.
      RootSpec carries intent, intact, from the first question to the last test.
    </p>

    <div style="margin-top: 2.5rem; display: flex; gap: 1rem; flex-wrap: wrap;">
      <a
        href="https://github.com/rootspec/rootspec"
        target="_blank"
        rel="noopener noreferrer"
        style="font-family: system-ui, sans-serif; font-size: 0.9375rem; background-color: var(--color-accent); color: #fff; padding: 0.625rem 1.25rem; border-radius: 4px; text-decoration: none; transition: background-color 150ms ease-out;"
      >
        View on GitHub
      </a>
    </div>
  </div>

  <!-- SVG Diagram -->
  <div style="margin-top: 4rem;">
    <svg
      viewBox="0 0 640 240"
      width="100%"
      style="max-width: 600px; display: block;"
      role="img"
      aria-label="RootSpec methodology diagram: spec surrounds development cycle, only valid solutions pass through"
    >
      <!-- Development cycle circle -->
      <circle cx="320" cy="120" r="70" fill="none" stroke="var(--color-border)" stroke-width="1.5" stroke-dasharray="6 3" />
      <text x="320" y="115" text-anchor="middle" font-family="system-ui, sans-serif" font-size="11" fill="var(--color-text-secondary)">Dev</text>
      <text x="320" y="130" text-anchor="middle" font-family="system-ui, sans-serif" font-size="11" fill="var(--color-text-secondary)">Cycle</text>

      <!-- Spec rectangle surrounding dev cycle -->
      <rect x="180" y="40" width="280" height="160" rx="6" fill="none" stroke="var(--color-accent)" stroke-width="1.5" />
      <text x="320" y="30" text-anchor="middle" font-family="'Courier New', monospace" font-size="11" fill="var(--color-accent)">SPEC</text>

      <!-- Input arrow (Intent) -->
      <line x1="60" y1="120" x2="175" y2="120" stroke="var(--color-text-secondary)" stroke-width="1.5" marker-end="url(#arrow)" />
      <text x="30" y="115" font-family="system-ui, sans-serif" font-size="10" fill="var(--color-text-secondary)">Intent</text>

      <!-- Valid output arrow -->
      <line x1="465" y1="105" x2="560" y2="105" stroke="var(--color-accent)" stroke-width="1.5" marker-end="url(#arrow-accent)" />
      <text x="467" y="97" font-family="system-ui, sans-serif" font-size="10" fill="var(--color-accent)">Valid</text>

      <!-- Invalid blocked arrow -->
      <line x1="465" y1="135" x2="540" y2="135" stroke="var(--color-border)" stroke-width="1.5" />
      <text x="550" y="139" font-family="system-ui, sans-serif" font-size="10" fill="var(--color-text-secondary)">✗</text>
      <text x="467" y="127" font-family="system-ui, sans-serif" font-size="10" fill="var(--color-text-secondary)">Invalid</text>

      <defs>
        <marker id="arrow" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
          <path d="M0,0 L0,6 L6,3 z" fill="var(--color-text-secondary)" />
        </marker>
        <marker id="arrow-accent" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
          <path d="M0,0 L0,6 L6,3 z" fill="var(--color-accent)" />
        </marker>
      </defs>
    </svg>
  </div>
</section>
