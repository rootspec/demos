---
const ROOTSPEC_VERSION = '7.3.7';
---
<section
  data-test="hero"
  class="py-24 px-4 text-center"
  style="background: linear-gradient(180deg, var(--color-surface) 0%, var(--color-bg) 100%);"
>
  <div class="section-container">
    <div class="inline-flex items-center gap-2 mb-6">
      <span
        data-test="version-badge"
        class="text-xs font-mono font-semibold px-3 py-1 rounded-full"
        style="background-color: var(--color-surface-alt); color: var(--color-primary); border: 1px solid var(--color-border);"
      >
        v{ROOTSPEC_VERSION}
      </span>
    </div>
    <h1 class="text-5xl font-extrabold tracking-tight mb-6" style="color: var(--color-text);">
      Build software from<br />
      <span style="color: var(--color-primary);">intent</span>, not assumption
    </h1>
    <p class="text-xl max-w-2xl mx-auto mb-10" style="color: var(--color-text-muted);">
      RootSpec is a structured specification methodology that aligns your team around
      a single source of truth — before a single line of code is written.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a
        href="#how-it-works"
        class="px-6 py-3 rounded-lg font-semibold text-white transition-colors"
        style="background-color: var(--color-primary);"
      >
        See how it works
      </a>
      <a
        href="#spec-wizard"
        class="px-6 py-3 rounded-lg font-semibold transition-colors"
        style="border: 1px solid var(--color-border); color: var(--color-text);"
      >
        Try the spec wizard
      </a>
    </div>
  </div>
</section>
