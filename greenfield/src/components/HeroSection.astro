<section data-test="hero-section" class="py-24 px-4 text-center bg-gradient-to-b from-purple-50 to-white dark:from-purple-950/30 dark:to-[var(--bg)]">
  <div class="max-w-4xl mx-auto">
    <h1 data-test="hero-headline" class="text-5xl md:text-6xl font-extrabold tracking-tight mb-6 text-[var(--fg)]">
      Ship products that match<br />
      <span class="text-purple-600 dark:text-purple-400">what you actually meant.</span>
    </h1>
    <p class="text-xl text-[var(--muted)] mb-8 max-w-2xl mx-auto">
      RootSpec is a spec-first methodology that bridges the gap between product vision and working code — automatically, verifiably, repeatably.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a
        href="#how-it-works"
        class="px-6 py-3 bg-purple-600 text-white rounded-lg font-medium hover:bg-purple-700 transition-colors"
      >See how it works</a>
      <a
        href="#spec-wizard"
        class="px-6 py-3 border border-[var(--border)] rounded-lg font-medium hover:bg-[var(--card)] transition-colors"
      >Try the wizard</a>
    </div>
  </div>
</section>
