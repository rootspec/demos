---
const version = '7.2.4';
---

<section class="py-20 px-4 text-center bg-gradient-to-b from-slate-50 to-white dark:from-slate-900 dark:to-slate-800">
  <div class="max-w-4xl mx-auto">
    <span
      data-test="version-badge"
      class="inline-block mb-4 px-3 py-1 bg-indigo-100 dark:bg-indigo-900 text-indigo-700 dark:text-indigo-300 text-xs font-mono rounded-full border border-indigo-200 dark:border-indigo-700"
    >
      v{version}
    </span>

    <h1
      data-test="hero-tagline"
      class="text-5xl font-bold mb-4 bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent"
    >
      Spec-first. AI-ready. Actually works.
    </h1>

    <p
      data-test="hero-subheading"
      class="text-xl text-slate-600 dark:text-slate-300 mb-8 max-w-2xl mx-auto"
    >
      RootSpec is a structured specification methodology that turns a one-line product idea into a complete, testable, AI-implementable spec in minutes.
    </p>

    <div class="flex gap-4 justify-center flex-wrap">
      <a
        href="#spec-wizard"
        class="px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg transition-colors"
      >
        Try It Now
      </a>
      <a
        data-test="cta-github-link"
        href="https://github.com/rootspec/rootspec"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-3 border border-slate-300 dark:border-slate-600 hover:bg-slate-100 dark:hover:bg-slate-800 font-semibold rounded-lg transition-colors"
      >
        View on GitHub
      </a>
    </div>
  </div>
</section>
