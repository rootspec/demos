---
const VERSION = '7.3.0';
---

<section
  data-test="hero-section"
  class="relative min-h-[80vh] flex flex-col items-center justify-center px-4 py-24 text-center overflow-hidden"
>
  <!-- Background grid -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(139,92,246,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(139,92,246,0.03)_1px,transparent_1px)] bg-[size:40px_40px] pointer-events-none" />

  <div class="relative z-10 max-w-4xl mx-auto">
    <!-- Version badge -->
    <div class="mb-6 flex justify-center">
      <span
        data-test="version-badge"
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-mono border border-accent-500/30 bg-accent-500/10 text-accent-400"
      >
        <span class="w-2 h-2 rounded-full bg-accent-400 animate-pulse"></span>
        RootSpec v{VERSION}
      </span>
    </div>

    <!-- Tagline -->
    <h1
      data-test="hero-tagline"
      class="text-5xl md:text-7xl font-bold tracking-tight mb-6 leading-tight"
    >
      Spec-first.<br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-400 to-brand-500">
        AI-powered.
      </span>
    </h1>

    <p class="text-xl md:text-2xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-8 leading-relaxed">
      RootSpec is a structured methodology for writing AI-executable specifications that turn into working software — without the guesswork.
    </p>

    <div class="flex flex-wrap gap-4 justify-center">
      <a
        href="#cta"
        class="px-6 py-3 rounded-lg bg-accent-600 hover:bg-accent-500 text-white font-semibold transition-colors"
      >
        Get started →
      </a>
      <a
        href="#workflow"
        class="px-6 py-3 rounded-lg border border-white/20 hover:border-white/40 text-[var(--text-primary)] font-semibold transition-colors"
      >
        How it works
      </a>
    </div>
  </div>
</section>
