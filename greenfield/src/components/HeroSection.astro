---
const VERSION = '7.2.4';
---

<section
  data-test="hero-section"
  class="relative min-h-[90vh] flex flex-col items-center justify-center text-center px-4 py-24 overflow-hidden"
>
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-brand-primary/10 via-transparent to-transparent pointer-events-none"></div>

  <!-- Version badge -->
  <div
    data-test="version-badge"
    class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-brand-primary/40 bg-brand-primary/10 text-brand-primary text-sm font-medium mb-8 animate-fade-in"
  >
    <span class="w-2 h-2 rounded-full bg-brand-primary inline-block"></span>
    v{VERSION}
  </div>

  <!-- Headline -->
  <h1
    data-test="hero-headline"
    class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-extrabold tracking-tight mb-6 max-w-4xl leading-tight"
  >
    Spec-driven AI development<br />
    <span class="text-brand-primary">that actually works</span>
  </h1>

  <!-- Subheadline -->
  <p
    data-test="hero-subheadline"
    class="text-lg sm:text-xl text-[var(--text-secondary)] max-w-2xl mb-10 leading-relaxed"
  >
    RootSpec turns your product idea into a structured, five-level specification
    that AI agents can implement, test, and validate — autonomously.
  </p>

  <!-- CTA buttons -->
  <div class="flex flex-col sm:flex-row gap-4 items-center">
    <a
      data-test="hero-cta"
      href="https://github.com/rootspec/rootspec"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg bg-brand-primary hover:bg-brand-secondary text-white font-semibold text-base transition-colors shadow-lg shadow-brand-primary/25"
    >
      Get started on GitHub
    </a>
    <a
      href="#workflow"
      class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg border border-[var(--border-color)] text-[var(--text-primary)] hover:bg-[var(--bg-secondary)] font-semibold text-base transition-colors"
    >
      See how it works
    </a>
  </div>
</section>
