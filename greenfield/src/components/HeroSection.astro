---
const version = '7.2.0';
---

<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-eyebrow section-label">Open-source dev methodology</div>
      <h1 class="hero-headline">
        Spec first.<br />Ship with confidence.
      </h1>
      <p data-test="hero-tagline" class="hero-tagline">
        RootSpec is a five-level specification methodology that transforms a sparse product description into a fully validated, implementation-ready development spec — without GPT hallucinations or vague requirements.
      </p>
      <div class="hero-actions">
        <a data-test="cta-github" href="https://github.com/rootspec/rootspec" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          View on GitHub
        </a>
        <a href="#hierarchy" class="btn btn-secondary">
          Explore the methodology
        </a>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <div class="spec-preview">
        <div class="spec-line spec-l1">L1 · Philosophy</div>
        <div class="spec-line spec-l2">L2 · Truths</div>
        <div class="spec-line spec-l3">L3 · Interactions</div>
        <div class="spec-line spec-l4">L4 · Systems</div>
        <div class="spec-line spec-l5 spec-l5-active">L5 · Implementation ✓</div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 5rem 0 4rem;
    background: var(--color-bg);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-eyebrow {
    margin-bottom: 1rem;
  }

  .hero-headline {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    color: var(--color-text-primary);
  }

  .hero-tagline {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: all 0.15s ease;
  }

  .btn-primary {
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    color: white;
    text-decoration: none;
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
  }

  .btn-secondary:hover {
    background: var(--color-border);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  /* Hero visual */
  .spec-preview {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 1.5rem;
    font-family: monospace;
  }

  .spec-line {
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    margin-bottom: 0.375rem;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    background: var(--color-bg);
  }

  .spec-l5-active {
    background: var(--color-accent);
    color: white;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-visual {
      order: -1;
    }
  }
</style>
