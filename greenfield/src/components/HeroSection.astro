---
const ROOTSPEC_VERSION = 'v7.3.4';
---
<section data-test="hero-section" class="relative overflow-hidden px-6 py-24 md:py-36 text-center">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-950/50 to-transparent pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto">
    <!-- Version badge -->
    <div class="flex justify-center mb-6">
      <span
        data-test="version-badge"
        class="inline-flex items-center gap-2 bg-brand-900/50 border border-brand-700 text-brand-300 text-sm font-mono px-3 py-1 rounded-full"
      >
        <span class="w-2 h-2 rounded-full bg-brand-400 animate-pulse"></span>
        Built with RootSpec {ROOTSPEC_VERSION}
      </span>
    </div>

    <!-- Headline -->
    <h1
      data-test="hero-heading"
      class="text-4xl md:text-6xl font-bold tracking-tight text-[var(--color-text)] mb-6"
    >
      Specs first.<br />
      <span class="text-brand-400">Clarity always.</span>
    </h1>

    <p class="text-lg md:text-xl text-[var(--color-text)]/70 max-w-2xl mx-auto mb-10">
      RootSpec is a structured specification methodology that keeps your team aligned from product vision to deployed code.
    </p>

    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="https://github.com/rootspec/rootspec"
        target="_blank"
        rel="noopener noreferrer"
        data-test="github-cta-link"
        class="inline-flex items-center gap-2 bg-brand-600 hover:bg-brand-500 text-white px-6 py-3 rounded-lg font-medium transition-colors"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
      <a
        href="#spec-wizard"
        class="inline-flex items-center gap-2 border border-brand-600 text-brand-300 hover:bg-brand-900/50 px-6 py-3 rounded-lg font-medium transition-colors"
      >
        Try the Wizard
      </a>
    </div>
  </div>
</section>
