---
import HierarchyExplorer from './HierarchyExplorer.tsx';
import SpecWizard from './SpecWizard.tsx';
import ComparisonSlider from './ComparisonSlider.tsx';
---

<section class="interactive-section">
  <div class="container">
    <h2>Try RootSpec Interactive Features</h2>

    <div class="feature-section">
      <h3>Explore the Five-Level Hierarchy</h3>
      <p>Click to expand levels and see how RootSpec structures specifications:</p>
      <HierarchyExplorer client:load />
    </div>

    <div class="feature-section">
      <h3>Generate Your Spec</h3>
      <p>Walk through our wizard to create a skeleton specification for your project:</p>
      <SpecWizard client:load />
    </div>

    <div class="feature-section">
      <h3>See the Difference</h3>
      <p>Slide to compare traditional specification approaches with RootSpec methodology:</p>
      <ComparisonSlider client:load />
    </div>
  </div>
</section>

<style>
  .interactive-section {
    padding: 4rem 0;
    background-color: var(--bg-gray);
  }

  .interactive-section h2 {
    font-size: 2.5rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 3rem;
    color: var(--text-dark);
  }

  .feature-section {
    margin: 4rem 0;
  }

  .feature-section h3 {
    font-size: 2rem;
    font-weight: 600;
    text-align: center;
    margin-bottom: 1rem;
    color: var(--text-dark);
  }

  .feature-section p {
    font-size: 1.125rem;
    color: var(--text-light);
    text-align: center;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 768px) {
    .interactive-section {
      padding: 3rem 0;
    }

    .interactive-section h2 {
      font-size: 2rem;
    }

    .feature-section h3 {
      font-size: 1.5rem;
    }
  }
</style>