<footer data-test="footer" class="py-10 px-4 border-t border-[var(--border)] bg-[var(--bg)]">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-[var(--muted)]">
    <div data-test="footer-attribution">
      Built with <a href="https://github.com/rootspec/rootspec" class="underline hover:text-[var(--fg)]">RootSpec</a> — spec-first development methodology.
      <span class="ml-2">© {new Date().getFullYear()} RootSpec Contributors</span>
    </div>
    <div class="flex gap-4">
      <a href="https://github.com/rootspec/rootspec" class="hover:text-[var(--fg)] transition-colors">GitHub</a>
      <a href="https://github.com/rootspec/demos" class="hover:text-[var(--fg)] transition-colors">Demos</a>
    </div>
  </div>
</footer>
