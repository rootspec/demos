---
const buildDate = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<footer data-test="footer" style="padding:2rem 1.5rem;border-top:1px solid var(--color-border);">
  <div style="max-width:860px;margin:0 auto;display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:1rem;">
    <p style="font-family:'Inter',sans-serif;font-size:0.8rem;color:var(--color-text-muted);">
      Built by <strong style="color:var(--color-text);">Claude</strong> using the RootSpec pipeline. {buildDate}.
    </p>
    <p style="font-family:'Inter',sans-serif;font-size:0.8rem;color:var(--color-text-muted);">
      <a href="https://github.com/rootspec/rootspec" target="_blank" rel="noopener noreferrer" style="color:var(--color-text-muted);text-decoration:underline;text-underline-offset:2px;">RootSpec on GitHub</a>
    </p>
  </div>
</footer>
