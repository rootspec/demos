---
const buildDate = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<footer data-test="footer" style="background-color: var(--bg-secondary); border-top: 1px solid var(--border); padding: 2rem 1.5rem;">
  <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem;">
    <div data-test="footer-attribution" style="color: var(--text-muted); font-size: 0.875rem;">
      Built with <strong style="color: var(--text-secondary);">RootSpec</strong> by the RootSpec team. Build date: <span>{buildDate}</span>
    </div>
    <div style="color: var(--text-muted); font-size: 0.8rem;">
      <a href="https://github.com/rootspec/demos" target="_blank" rel="noopener noreferrer" style="color: var(--text-muted);">GitHub</a>
      <span style="margin: 0 0.5rem;">·</span>
      <span>MIT License</span>
    </div>
  </div>
</footer>
