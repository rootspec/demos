---
const buildDate = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<footer
  data-test="footer"
  class="py-10 px-6 mt-16"
  style="border-top: 1px solid var(--color-border);"
>
  <div class="max-w-4xl mx-auto flex flex-col md:flex-row justify-between items-start gap-4">
    <div>
      <p class="font-sans text-sm" style="color: var(--color-text-muted);">
        Built by <strong>Claude</strong> (Anthropic) · {buildDate}
      </p>
      <p class="font-sans text-xs mt-1" style="color: var(--color-text-muted); opacity: 0.7;">
        Generated from a RootSpec seed with no manual code.
      </p>
    </div>
    <div class="flex gap-4">
      <a
        href="https://github.com/rootspec/rootspec"
        class="font-sans text-sm no-underline"
        style="color: var(--color-text-muted);"
      >
        GitHub
      </a>
      <a
        href="https://github.com/rootspec/demos/tree/main/greenfield"
        class="font-sans text-sm no-underline"
        style="color: var(--color-text-muted);"
      >
        This demo
      </a>
    </div>
  </div>
</footer>
