---
const buildDate = new Date().toISOString().slice(0, 10);
---

<footer style="background-color: var(--color-bg); border-top: 1px solid var(--color-border); padding: 2rem 1.5rem;">
  <div style="max-width: 1100px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: space-between; align-items: center;">
    <p style="font-size: 0.8125rem; color: var(--color-text-secondary); margin: 0;">
      Built by Claude (Anthropic) · {buildDate}
    </p>
    <p style="font-size: 0.8125rem; color: var(--color-text-secondary); margin: 0;">
      <a
        href="https://github.com/rootspec/rootspec"
        target="_blank"
        rel="noopener noreferrer"
        style="color: var(--color-text-secondary);"
      >
        github.com/rootspec/rootspec
      </a>
    </p>
  </div>
</footer>
