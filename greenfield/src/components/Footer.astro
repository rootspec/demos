---
import { readFileSync } from 'fs';
import { join } from 'path';

let version = '7.5.0';
try {
  const raw = readFileSync(join(process.cwd(), '.rootspec.json'), 'utf-8');
  const parsed = JSON.parse(raw);
  version = parsed.version || version;
} catch {
  // fallback
}

const buildYear = new Date().getFullYear();
---

<footer
  data-test="footer"
  style="border-top: 1px solid var(--color-border); padding: 2rem 1.5rem; font-family: system-ui, sans-serif; font-size: 0.875rem; color: var(--color-text-secondary);"
>
  <div style="max-width: 72rem; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 1rem; justify-content: space-between; align-items: center;">
    <div>
      Built by Claude (claude-sonnet-4-6) using RootSpec v{version} · {buildYear}
    </div>
    <div>
      <a
        href="https://github.com/rootspec/rootspec"
        target="_blank"
        rel="noopener noreferrer"
        style="color: var(--color-link);"
      >
        github.com/rootspec/rootspec
      </a>
    </div>
  </div>
</footer>
