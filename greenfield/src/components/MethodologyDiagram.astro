---
---
<section style="padding:5rem 1.5rem;background:var(--color-bg);">
  <div style="max-width:64rem;margin:0 auto;">
    <h2 style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;margin:0 0 2rem;text-align:center;color:var(--color-text);">The RootSpec Hierarchy</h2>
    <div data-test="methodology-diagram" style="overflow-x:auto;">
      <div style="display:flex;flex-direction:column;gap:0.75rem;min-width:0;max-width:40rem;margin:0 auto;">
        {[
          { level: 'L1', label: 'Philosophy', desc: 'Why this product exists' },
          { level: 'L2', label: 'Truths', desc: 'Non-negotiable constraints' },
          { level: 'L3', label: 'Interactions', desc: 'How users engage' },
          { level: 'L4', label: 'Systems', desc: 'Component architecture' },
          { level: 'L5', label: 'Implementation', desc: 'User stories & tests' },
        ].map((item) => (
          <div style="display:flex;align-items:center;gap:1rem;background:var(--color-surface);border:1px solid var(--color-border);border-radius:0.625rem;padding:0.875rem 1.25rem;">
            <div style="background:var(--color-primary);color:white;border-radius:0.375rem;padding:0.25rem 0.625rem;font-size:0.8rem;font-weight:700;white-space:nowrap;">{item.level}</div>
            <div>
              <div style="font-weight:600;color:var(--color-text);">{item.label}</div>
              <div style="font-size:0.85rem;color:var(--color-text-muted);">{item.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
