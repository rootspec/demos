---
---

<section class="py-16 px-4 bg-[var(--bg-secondary)]">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold mb-3">The Methodology</h2>
      <p class="text-[var(--text-secondary)]">A closed loop from idea to verified software.</p>
    </div>

    <div
      data-test="methodology-diagram"
      class="relative flex flex-col md:flex-row items-center justify-center gap-4 md:gap-0"
    >
      <!-- Nodes -->
      {[
        { label: 'SEED', sub: 'Product Idea', color: 'border-brand-500/40 bg-brand-500/5 text-brand-400' },
        { label: 'SPEC', sub: 'L1–L5 Docs', color: 'border-accent-500/40 bg-accent-500/5 text-accent-400' },
        { label: 'IMPL', sub: 'Working Code', color: 'border-green-500/40 bg-green-500/5 text-green-400' },
        { label: 'VALIDATE', sub: 'Pass/Fail Report', color: 'border-yellow-500/40 bg-yellow-500/5 text-yellow-400' },
      ].map((node, i, arr) => (
        <div class="flex items-center">
          <div class={`flex flex-col items-center justify-center w-28 h-28 rounded-xl border ${node.color} text-center`}>
            <span class="font-mono font-bold text-sm">{node.label}</span>
            <span class="text-xs text-[var(--text-secondary)] mt-1">{node.sub}</span>
          </div>
          {i < arr.length - 1 && (
            <div class="hidden md:flex items-center mx-2 text-[var(--text-secondary)]">
              <div class="w-8 border-t border-dashed border-white/20" />
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
          )}
        </div>
      ))}

      <!-- Feedback arrow on mobile -->
      <div class="md:hidden w-px h-8 border-l border-dashed border-white/20 mx-auto" />
    </div>

    <p class="text-center text-sm text-[var(--text-secondary)] mt-8">
      The loop is repeatable. Each iteration tightens the spec → code → validation cycle.
    </p>
  </div>
</section>
