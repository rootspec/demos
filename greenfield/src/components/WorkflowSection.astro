---
const steps = [
  {
    num: '01',
    cmd: '/rs-init',
    title: 'Initialize',
    desc: 'Set up the RootSpec structure in your project with a single command.',
  },
  {
    num: '02',
    cmd: '/rs-spec',
    title: 'Specify',
    desc: 'Answer guided questions to generate a 5-level spec: philosophy, truths, interactions, systems, and user stories.',
  },
  {
    num: '03',
    cmd: '/rs-impl',
    title: 'Implement',
    desc: 'An AI agent reads the spec and builds your features — test-driven, autonomous, one story at a time.',
  },
  {
    num: '04',
    cmd: '/rs-validate',
    title: 'Validate',
    desc: 'Run automated tests against your spec. Every acceptance criterion is verified against the live app.',
  },
];
---
<section
  data-test="how-it-works"
  id="how-it-works"
  class="py-20 px-4"
  style="background-color: var(--color-bg);"
>
  <div class="section-container">
    <h2 class="text-3xl font-bold text-center mb-4" style="color: var(--color-text);">
      How RootSpec works
    </h2>
    <p class="text-center text-lg mb-14 max-w-2xl mx-auto" style="color: var(--color-text-muted);">
      Four commands. One source of truth. Software that ships what was actually intended.
    </p>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((s) => (
        <div
          class="rounded-xl p-6 flex flex-col gap-3"
          style="background-color: var(--color-surface); border: 1px solid var(--color-card-border);"
        >
          <div class="text-4xl font-extrabold opacity-20" style="color: var(--color-primary);">
            {s.num}
          </div>
          <code
            class="text-sm font-mono font-bold px-2 py-1 rounded self-start"
            style="background-color: var(--color-surface-alt); color: var(--color-primary);"
          >
            {s.cmd}
          </code>
          <h3 class="text-lg font-semibold" style="color: var(--color-text);">{s.title}</h3>
          <p class="text-sm" style="color: var(--color-text-muted);">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
