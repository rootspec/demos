---
const skills = [
  {
    command: '/rs-init',
    name: 'rs-init',
    title: 'Initialize',
    color: 'from-blue-500 to-blue-600',
    description: 'Sets up the spec directory structure. Creates axioms, framework anchors, and placeholder files for all five levels.',
    step: '01',
  },
  {
    command: '/rs-spec',
    name: 'rs-spec',
    title: 'Specify',
    color: 'from-violet-500 to-violet-600',
    description: 'Reads your product description and generates the full spec hierarchy — philosophy through implementation. Produces testable user stories.',
    step: '02',
  },
  {
    command: '/rs-impl',
    name: 'rs-impl',
    title: 'Implement',
    color: 'from-emerald-500 to-emerald-600',
    description: 'Turns stories into working code with Cypress tests. Implements one story at a time, verifying each against acceptance criteria.',
    step: '03',
  },
  {
    command: '/rs-validate',
    name: 'rs-validate',
    title: 'Validate',
    color: 'from-orange-500 to-orange-600',
    description: 'Runs the full test suite and produces a coverage report. Identifies gaps between what\'s specified and what\'s tested.',
    step: '04',
  },
];
---

<section id="how-it-works" data-test="how-it-works-section" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white mb-4">
        How it works
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-300 max-w-2xl mx-auto">
        Four skills drive every workflow. Run them in sequence or independently.
        Each command is idempotent — run it again at any time.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {skills.map((skill, i) => (
        <div class="relative group">
          {i < skills.length - 1 && (
            <div class="hidden lg:block absolute top-8 left-full w-full h-px bg-gradient-to-r from-slate-200 to-transparent dark:from-slate-700 z-10 -translate-x-3" />
          )}
          <div class="bg-white dark:bg-slate-800 rounded-xl p-6 border border-slate-200 dark:border-slate-700 shadow-sm hover:shadow-lg transition-all hover:-translate-y-1 h-full">
            <div class={`inline-flex w-10 h-10 rounded-lg bg-gradient-to-br ${skill.color} items-center justify-center text-white font-bold text-sm mb-4`}>
              {skill.step}
            </div>
            <code class="block text-sm font-mono font-semibold text-brand-600 dark:text-brand-400 mb-1">
              {skill.command}
            </code>
            <h3 class="font-semibold text-slate-900 dark:text-white mb-2">{skill.name}</h3>
            <p class="text-sm text-slate-600 dark:text-slate-300 leading-relaxed">{skill.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Key messages -->
    <div class="mt-12 grid sm:grid-cols-3 gap-4">
      <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-5 border border-slate-200 dark:border-slate-700">
        <p class="text-sm font-medium text-slate-900 dark:text-white mb-1">Declarative, not prescriptive</p>
        <p class="text-sm text-slate-500 dark:text-slate-400">You declare what the product is and why it exists. The spec derives everything else.</p>
      </div>
      <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-5 border border-slate-200 dark:border-slate-700">
        <p class="text-sm font-medium text-slate-900 dark:text-white mb-1">Philosophy-stable</p>
        <p class="text-sm text-slate-500 dark:text-slate-400">Implementation changes don't break the spec. Philosophy only changes when your mission changes.</p>
      </div>
      <div class="bg-slate-50 dark:bg-slate-800/50 rounded-lg p-5 border border-slate-200 dark:border-slate-700">
        <p class="text-sm font-medium text-slate-900 dark:text-white mb-1">AI-compatible</p>
        <p class="text-sm text-slate-500 dark:text-slate-400">AI executes implementation. Humans supply philosophy. The spec bridges the gap reliably.</p>
      </div>
    </div>
  </div>
</section>
