---
const skills = [
  {
    name: 'rs-init',
    step: '01',
    tagline: 'Bootstrap your spec',
    desc: 'Creates the directory structure and axiom files. Establishes the philosophical foundation before any implementation decisions.',
    color: 'var(--brand)',
  },
  {
    name: 'rs-spec',
    step: '02',
    tagline: 'Fill all five levels',
    desc: 'Interviews you about mission, pillars, truths, and interactions. Derives systems architecture from your philosophy, not the other way around.',
    color: 'var(--brand)',
  },
  {
    name: 'rs-impl',
    step: '03',
    tagline: 'Implement from stories',
    desc: 'Takes validated user stories and builds test-driven implementation. Every feature traces back to a design pillar.',
    color: 'var(--accent)',
  },
  {
    name: 'rs-validate',
    step: '04',
    tagline: 'Run the validation gate',
    desc: 'Executes all tests, generates coverage report, and confirms spec alignment. Pass or fail — no ambiguity.',
    color: 'var(--accent)',
  },
];
---

<section data-test="how-it-works" class="section-spacing" style="background: var(--bg);">
  <div class="container-content">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4" style="color: var(--fg);">How it works</h2>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--muted);">
        Four skills cover the full specification lifecycle — from blank slate to validated implementation.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {skills.map((skill) => (
        <div class="card flex gap-4">
          <div class="flex-shrink-0">
            <span
              class="text-xs font-mono px-2 py-0.5 rounded-full"
              style={`background: ${skill.color}22; color: ${skill.color}; border: 1px solid ${skill.color}44;`}
            >
              {skill.step}
            </span>
          </div>
          <div>
            <code class="text-sm font-mono font-bold" style={`color: ${skill.color};`}>{skill.name}</code>
            <p class="font-semibold text-sm mt-1 mb-1" style="color: var(--fg);">{skill.tagline}</p>
            <p class="text-sm leading-relaxed" style="color: var(--muted);">{skill.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
