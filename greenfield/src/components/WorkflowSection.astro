---
---
<section
  id="how-it-works"
  data-test="how-it-works"
  class="w-full py-20 px-4"
  style="background-color:var(--bg);"
>
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center" style="color:var(--text);">
      Four skills. One methodology.
    </h2>
    <p class="text-center mb-12 text-lg" style="color:var(--text-muted);">
      RootSpec gives AI agents a structured workflow to build software correctly, every time.
    </p>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {[
        { step: '01', name: 'rs-init', label: 'Initialize', desc: 'Bootstrap the project with spec scaffolding and conventions.' },
        { step: '02', name: 'rs-spec', label: 'Specify', desc: 'Write L1–L5 spec from a SEED.md product description.' },
        { step: '03', name: 'rs-impl', label: 'Implement', desc: 'Build features from user stories with test-driven development.' },
        { step: '04', name: 'rs-validate', label: 'Validate', desc: 'Run tests, generate a report, and verify spec completeness.' },
      ].map(({ step, name, label, desc }) => (
        <div class="p-6 rounded-xl border flex flex-col gap-3" style="background-color:var(--surface);border-color:var(--border);">
          <span class="text-xs font-mono font-bold" style="color:var(--accent);">STEP {step}</span>
          <code class="text-sm font-mono font-bold px-2 py-1 rounded" style="background-color:var(--bg);color:var(--text);">/{name}</code>
          <h3 class="font-bold" style="color:var(--text);">{label}</h3>
          <p class="text-sm" style="color:var(--text-muted);">{desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
