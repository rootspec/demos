---
const skills = [
  {
    name: 'rs-init',
    tagline: 'Initialize',
    description: 'Scaffold a RootSpec project with all required directories, config files, and CI/CD hooks in one command.',
    step: '01',
  },
  {
    name: 'rs-spec',
    tagline: 'Specify',
    description: 'Transform a product idea into a five-level living specification — from philosophy down to testable user stories.',
    step: '02',
  },
  {
    name: 'rs-impl',
    tagline: 'Implement',
    description: 'Build features autonomously from validated user stories, driven by Cypress tests that prove each acceptance criterion.',
    step: '03',
  },
  {
    name: 'rs-validate',
    tagline: 'Validate',
    description: 'Run the full test suite, generate a coverage report, and confirm all stories pass before shipping.',
    step: '04',
  },
];
---
<section data-test="how-it-works-section" id="how-it-works" style="padding: 5rem 1.5rem;">
  <div style="max-width: 1100px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h2 style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; margin: 0 0 0.75rem; color: var(--color-text);">
        How It Works
      </h2>
      <p style="color: var(--color-text-muted); font-size: 1.1rem; max-width: 560px; margin: 0 auto;">
        Four skills. One workflow. From idea to verified implementation.
      </p>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem;">
      {skills.map(s => (
        <div style="
          background: var(--color-surface);
          border: 1px solid var(--color-border);
          border-radius: 0.75rem;
          padding: 1.75rem 1.5rem;
          position: relative;
          overflow: hidden;
        ">
          <div style="
            position: absolute;
            top: 1rem;
            right: 1rem;
            font-size: 3rem;
            font-weight: 800;
            color: rgba(99,102,241,0.1);
            line-height: 1;
          ">{s.step}</div>
          <div style="
            font-family: monospace;
            font-size: 0.9rem;
            color: var(--color-accent-bright);
            font-weight: 600;
            margin-bottom: 0.4rem;
            background: rgba(99,102,241,0.1);
            display: inline-block;
            padding: 0.2rem 0.6rem;
            border-radius: 0.25rem;
          ">{s.name}</div>
          <h3 style="font-size: 1.1rem; font-weight: 600; margin: 0.5rem 0; color: var(--color-text);">{s.tagline}</h3>
          <p style="color: var(--color-text-muted); font-size: 0.875rem; line-height: 1.55; margin: 0;">{s.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
