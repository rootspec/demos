---
const skills = [
  {
    cmd: 'rs-init',
    label: 'Initialize',
    description: 'Bootstrap the spec structure and file hierarchy for your project.',
    color: 'text-blue-500',
  },
  {
    cmd: 'rs-spec',
    label: 'Specify',
    description: 'Translate a product description into a validated five-level specification.',
    color: 'text-purple-500',
  },
  {
    cmd: 'rs-impl',
    label: 'Implement',
    description: 'Generate working code from user stories, one acceptance criterion at a time.',
    color: 'text-indigo-500',
  },
  {
    cmd: 'rs-validate',
    label: 'Validate',
    description: 'Run tests, measure coverage, and produce a machine-readable quality report.',
    color: 'text-green-500',
  },
];
---

<section
  id="how-it-works"
  data-test="how-it-works"
  class="py-20 px-4"
>
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        Four skills. One coherent workflow.
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        RootSpec gives your AI agent a repeatable, structured process — from idea to shipping code.
      </p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {skills.map((skill, i) => (
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700 shadow-sm">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-gray-400 text-sm font-mono">0{i + 1}</span>
            <span class={`font-mono font-bold ${skill.color}`}>{skill.cmd}</span>
          </div>
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">{skill.label}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">{skill.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
