---
---
<section
  id="how-it-works"
  data-test="how-it-works"
  style="padding:5rem 1.5rem;"
>
  <div style="max-width:900px;margin:0 auto;">
    <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;color:var(--accent);text-transform:uppercase;margin-bottom:0.75rem;">How it works</p>
    <h2 style="font-size:clamp(1.75rem,4vw,2.75rem);font-weight:700;margin-bottom:1rem;letter-spacing:-0.02em;">
      Four skills. One cohesive spec.
    </h2>
    <p style="color:var(--muted);font-size:1.0625rem;line-height:1.65;max-width:580px;margin-bottom:3rem;">
      RootSpec provides four agent skills that guide your project from first idea to production-ready implementation.
    </p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.25rem;">
      {[
        { cmd: 'rs-init', label: 'Initialize', desc: 'Bootstrap your project structure and RootSpec configuration from a seed description.' },
        { cmd: 'rs-spec', label: 'Specify', desc: 'Generate and refine all five specification levels — from philosophy to user stories.' },
        { cmd: 'rs-impl', label: 'Implement', desc: 'Turn validated user stories into working code, one story at a time, test-driven.' },
        { cmd: 'rs-validate', label: 'Validate', desc: 'Run the full test suite and generate a spec compliance report.' },
      ].map(({ cmd, label, desc }) => (
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:0.75rem;padding:1.5rem;">
          <code style="font-size:0.8125rem;color:var(--accent-light);background:var(--bg);border:1px solid var(--border);padding:0.2rem 0.5rem;border-radius:0.25rem;display:inline-block;margin-bottom:0.875rem;">{cmd}</code>
          <h3 style="font-weight:600;margin-bottom:0.5rem;">{label}</h3>
          <p style="color:var(--muted);font-size:0.9rem;line-height:1.6;">{desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
