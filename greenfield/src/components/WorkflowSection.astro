---
const steps = [
  {
    command: 'rs-init',
    title: 'Initialize',
    description: 'Scaffold the spec directory structure and conventions for your project.',
    number: '01',
  },
  {
    command: 'rs-spec',
    title: 'Specify',
    description: 'AI interviews you about your product and generates a five-level spec from your seed.',
    number: '02',
  },
  {
    command: 'rs-impl',
    title: 'Implement',
    description: 'AI reads the spec and builds features test-first, story by story, autonomously.',
    number: '03',
  },
  {
    command: 'rs-validate',
    title: 'Validate',
    description: 'Run the full test suite, check coverage, and generate a spec compliance report.',
    number: '04',
  },
];
---

<section
  data-test="workflow-section"
  id="workflow"
  class="py-24 px-4 bg-[var(--bg-secondary)]"
>
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">How RootSpec works</h2>
      <p class="text-[var(--text-secondary)] text-lg max-w-2xl mx-auto">
        Four commands. From idea to tested, shipped product.
      </p>
    </div>

    <div data-test="workflow-steps" class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {steps.map((step) => (
        <div
          data-test="workflow-step"
          class="relative p-6 rounded-xl border border-[var(--border-color)] bg-[var(--bg-primary)] hover:border-brand-primary/50 transition-all group"
        >
          <div class="text-xs font-mono text-[var(--text-secondary)] mb-4 opacity-50">{step.number}</div>
          <div class="mb-3">
            <code class="text-brand-primary font-mono font-semibold text-base bg-brand-primary/10 px-2 py-1 rounded">
              /{step.command}
            </code>
          </div>
          <h3 class="font-bold text-base mb-2">{step.title}</h3>
          <p class="text-sm text-[var(--text-secondary)] leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
