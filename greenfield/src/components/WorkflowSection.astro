---
import ComparisonSection from './ComparisonSection.tsx';
---

<section id="comparison" class="py-16 px-4 bg-slate-50 dark:bg-slate-800">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-4 text-slate-800 dark:text-slate-100">
      Requirements: Before &amp; After
    </h2>
    <p class="text-center text-slate-600 dark:text-slate-400 mb-10 max-w-2xl mx-auto">
      See the difference between unstructured requirements and a RootSpec user story.
    </p>
    <ComparisonSection client:only="react" />
  </div>
</section>
