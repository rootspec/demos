---
const BASE = import.meta.env.BASE_URL || '';
const specUrl = 'https://github.com/rootspec/demos/tree/main/greenfield/rootspec';
const seedUrl = 'https://github.com/rootspec/demos/blob/main/greenfield/SEED.md';
---

<div
  data-test="meta-banner"
  class="w-full py-2.5 px-4 text-sm text-center"
  style="background: var(--card); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 50;"
>
  <span class="text-[var(--muted)]">
    This site was generated from a ~100-line product description using the RootSpec pipeline — no manual code, no design mockups.&nbsp;
    <a
      data-test="meta-banner-spec-link"
      href={specUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="underline hover:opacity-80 transition-opacity"
      style="color: var(--brand);"
    >
      View the spec →
    </a>
    &nbsp;
    <a
      data-test="meta-banner-seed-link"
      href={seedUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="underline hover:opacity-80 transition-opacity"
      style="color: var(--brand);"
    >
      View the seed →
    </a>
  </span>
</div>
