---
// MetaBanner — shown above everything else on every page load
const SPEC_URL = 'https://github.com/anthropics/claude-code/tree/main/demos/greenfield/rootspec';
const SEED_URL = 'https://github.com/anthropics/claude-code/tree/main/demos/greenfield/SEED.md';
---
<div
  data-test="meta-banner"
  style="background-color: var(--color-meta-bg); color: var(--color-meta-text);"
  class="w-full text-sm py-2 px-4 flex flex-wrap gap-x-4 gap-y-1 justify-center items-center"
>
  <span class="opacity-75">Built with RootSpec —</span>
  <a
    data-test="spec-link"
    href={SPEC_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="underline hover:opacity-90 transition-opacity font-medium"
  >
    view spec
  </a>
  <span class="opacity-40">·</span>
  <a
    data-test="seed-link"
    href={SEED_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="underline hover:opacity-90 transition-opacity font-medium"
  >
    view seed
  </a>
</div>
