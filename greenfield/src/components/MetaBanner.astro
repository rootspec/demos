---
const SPEC_URL = 'https://github.com/rootspec/demos/tree/main/greenfield/rootspec';
const SEED_URL = 'https://github.com/rootspec/demos/tree/main/greenfield/SEED.md';
---

<div
  data-test="meta-banner"
  class="w-full bg-brand-primary/10 border-b border-brand-primary/30 px-4 py-2 text-center text-sm text-[var(--text-secondary)]"
>
  <span class="inline-flex items-center gap-3 flex-wrap justify-center">
    <span>🧪 This site was built by an AI agent using RootSpec</span>
    <a
      data-test="link-spec"
      href={SPEC_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="text-brand-primary hover:text-brand-secondary underline font-medium"
    >
      View the spec
    </a>
    <span class="opacity-40">·</span>
    <a
      data-test="link-seed"
      href={SEED_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="text-brand-primary hover:text-brand-secondary underline font-medium"
    >
      View the seed
    </a>
  </span>
</div>
