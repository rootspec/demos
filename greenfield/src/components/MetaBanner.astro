---
const GITHUB_BASE = 'https://github.com/anthropics/claude-code/tree/main/demos/greenfield';
const SPEC_LINK = `${GITHUB_BASE}/rootspec`;
const SEED_LINK = `${GITHUB_BASE}/SEED.md`;
---

<div
  data-test="meta-banner"
  class="w-full bg-accent-600/10 border-b border-accent-500/20 px-4 py-2 text-center text-sm"
>
  <span class="text-[var(--text-secondary)]">
    This is a <strong class="text-accent-400">RootSpec</strong> demo — built from spec using AI.
    &nbsp;
    <a
      data-test="meta-banner-spec-link"
      href={SPEC_LINK}
      target="_blank"
      rel="noopener noreferrer"
      class="text-brand-500 hover:text-brand-400 underline underline-offset-2"
    >View spec</a>
    &nbsp;·&nbsp;
    <a
      data-test="meta-banner-seed-link"
      href={SEED_LINK}
      target="_blank"
      rel="noopener noreferrer"
      class="text-brand-500 hover:text-brand-400 underline underline-offset-2"
    >View seed</a>
  </span>
</div>
