---
import SpecWizard from './SpecWizard';
---

<section id="wizard" class="wizard-section">
  <div class="container">
    <div class="section-label">Try it now</div>
    <h2>Spec your idea in 60 seconds</h2>
    <p class="section-desc">
      Walk through a stripped-down version of the RootSpec methodology and see how a product idea becomes a skeleton spec.
    </p>
    <div class="wizard-wrapper">
      <SpecWizard client:load />
    </div>
  </div>
</section>

<style>
  .wizard-section {
    background: var(--color-surface);
  }

  .wizard-section h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .section-desc {
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
    margin-bottom: 2.5rem;
    max-width: 520px;
  }

  .wizard-wrapper {
    max-width: 640px;
  }

  :global(.spec-wizard) {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
  }

  :global(.wizard-pane) {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  :global(.wizard-prompt) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  :global(.wizard-prompt-success) {
    color: var(--color-accent);
  }

  :global(.wizard-textarea),
  :global(.wizard-input) {
    width: 100%;
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    color: var(--color-text-primary);
    font-size: 0.9375rem;
    font-family: inherit;
    resize: vertical;
    line-height: 1.5;
  }

  :global(.wizard-textarea:focus),
  :global(.wizard-input:focus) {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
    border-color: transparent;
  }

  :global(.wizard-textarea-error) {
    border-color: #ef4444;
  }

  :global(.wizard-error) {
    color: #ef4444;
    font-size: 0.875rem;
    font-weight: 500;
    margin-top: -0.25rem;
  }

  :global(.wizard-options) {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.wizard-option) {
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    cursor: pointer;
    text-align: left;
    font-size: 0.9375rem;
    color: var(--color-text-primary);
    transition: all 0.1s ease;
  }

  :global(.wizard-option:hover) {
    border-color: var(--color-accent);
    background: var(--color-bg);
  }

  :global(.wizard-option-selected) {
    border-color: var(--color-accent);
    background: var(--color-bg);
    color: var(--color-accent);
    font-weight: 600;
  }

  :global(.wizard-btn) {
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.9375rem;
    border: none;
    cursor: pointer;
    font-family: inherit;
    align-self: flex-start;
    transition: all 0.15s ease;
  }

  :global(.wizard-btn-primary) {
    background: var(--color-accent);
    color: white;
  }

  :global(.wizard-btn-primary:hover) {
    background: var(--color-accent-hover);
  }

  :global(.wizard-btn-secondary) {
    background: var(--color-surface);
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
  }

  :global(.wizard-output) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: auto;
    max-height: 300px;
  }

  :global(.wizard-output pre) {
    border-radius: 0;
    font-size: 0.8125rem;
  }
</style>
