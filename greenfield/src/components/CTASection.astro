---
---
<section
  data-test="cta-section"
  class="w-full py-24 px-4 text-center"
  style="background:linear-gradient(135deg,var(--accent) 0%,var(--accent-dark,#0284c7) 100%);"
>
  <div class="max-w-2xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 text-white">
      Ready to build spec-first?
    </h2>
    <p class="text-lg mb-8 text-white opacity-90">
      RootSpec is open-source. Start with a SEED.md and let the agents do the rest.
    </p>
    <div class="flex gap-4 justify-center flex-wrap">
      <a
        href="https://github.com/anthropics/claude-code-demos"
        target="_blank"
        rel="noopener noreferrer"
        class="px-8 py-3 rounded-lg font-bold text-sm transition-opacity hover:opacity-90"
        style="background-color:#ffffff;color:var(--accent);"
      >
        View on GitHub
      </a>
    </div>
  </div>
</section>
