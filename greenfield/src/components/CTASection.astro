---
---
<section
  data-test="cta-section"
  class="py-16 px-6 max-w-4xl mx-auto"
>
  <div class="border-t pt-16" style="border-color: var(--color-border);">
    <h2 class="font-sans text-sm font-medium uppercase tracking-wider mb-6" style="color: var(--color-text-muted);">
      Get Started
    </h2>

    <h3 class="font-serif text-2xl md:text-3xl font-light mb-6 max-w-xl" style="color: var(--color-text);">
      RootSpec is open source. Start with four commands.
    </h3>

    <div class="rounded p-4 mb-8" style="background-color: var(--color-code-bg); border: 1px solid var(--color-border);">
      <pre class="font-mono text-sm" style="color: var(--color-text);"><code>{`/rs-init   # scaffold your project
/rs-spec   # specify your product
/rs-impl   # implement from spec
/rs-validate  # validate continuously`}</code></pre>
    </div>

    <div class="flex flex-wrap gap-4">
      <a
        href="https://github.com/rootspec/rootspec"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded font-sans text-sm font-medium no-underline transition-opacity"
        style="background-color: var(--color-accent); color: white;"
      >
        View on GitHub →
      </a>
      <a
        href="https://github.com/rootspec/rootspec#readme"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded font-sans text-sm font-medium no-underline"
        style="border: 1px solid var(--color-border); color: var(--color-text);"
      >
        Read the docs
      </a>
    </div>
  </div>
</section>
