---
---
<section
  data-test="cta-section"
  style="padding:5rem 1.5rem;text-align:center;background:var(--surface);border-top:1px solid var(--border);"
>
  <div style="max-width:600px;margin:0 auto;">
    <h2 style="font-size:clamp(1.75rem,4vw,2.5rem);font-weight:700;margin-bottom:1rem;letter-spacing:-0.02em;">
      Start specifying today
    </h2>
    <p style="color:var(--muted);font-size:1.0625rem;line-height:1.65;margin-bottom:2.5rem;">
      RootSpec is open-source and free. Install the agent skills and run your first spec in minutes.
    </p>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a
        href="https://github.com/rootspec/demos"
        target="_blank"
        rel="noopener"
        style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--accent);color:#fff;padding:0.875rem 2rem;border-radius:0.5rem;font-weight:600;text-decoration:none;font-size:1rem;"
      >
        ★ Star on GitHub
      </a>
      <a
        href="https://github.com/rootspec/demos/blob/main/greenfield/rootspec/01.PHILOSOPHY.md"
        target="_blank"
        rel="noopener"
        style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--bg);border:1px solid var(--border);color:var(--fg);padding:0.875rem 2rem;border-radius:0.5rem;font-weight:500;text-decoration:none;font-size:1rem;"
      >
        Read the spec
      </a>
    </div>
  </div>
</section>
