---
const GITHUB_URL = 'https://github.com/rootspec/rootspec';
---

<section
  data-test="cta-section"
  style="padding: 5rem 1.5rem; border-top: 1px solid var(--color-border); text-align: center;"
>
  <div style="max-width: 72rem; margin: 0 auto;">
    <h2 style="font-family: Georgia, serif; font-size: clamp(1.375rem, 3vw, 2rem); font-weight: 400; color: var(--color-text-primary); margin-bottom: 1rem;">
      Open source. Start today.
    </h2>
    <p style="font-family: Georgia, serif; font-size: 1rem; color: var(--color-text-secondary); max-width: 36rem; margin: 0 auto 2.5rem; line-height: 1.7;">
      RootSpec is free, open source, and works with any LLM-enabled development environment.
      Read the framework, explore the demos, and start your first spec.
    </p>
    <a
      href={GITHUB_URL}
      data-test="github-link"
      target="_blank"
      rel="noopener noreferrer"
      style="display: inline-block; font-family: system-ui, sans-serif; font-size: 0.9375rem; background-color: var(--color-accent); color: #fff; padding: 0.75rem 1.75rem; border-radius: 4px; text-decoration: none; transition: background-color 150ms ease-out;"
    >
      github.com/rootspec/rootspec
    </a>
  </div>
</section>
