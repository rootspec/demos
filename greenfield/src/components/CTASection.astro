---
---

<section
  data-test="cta-section"
  id="cta"
  class="py-24 px-4 bg-[var(--bg-secondary)]"
>
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-3xl sm:text-4xl font-bold mb-6">
      Ready to spec-drive your next project?
    </h2>
    <p class="text-[var(--text-secondary)] text-lg mb-10 leading-relaxed">
      RootSpec is open source. Install it, run <code class="font-mono text-brand-primary bg-brand-primary/10 px-2 py-0.5 rounded">/rs-init</code>, and ship your first AI-built feature with confidence.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        data-test="cta-github-link"
        href="https://github.com/rootspec/rootspec"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg bg-brand-primary hover:bg-brand-secondary text-white font-semibold text-base transition-colors shadow-lg shadow-brand-primary/25"
      >
        View on GitHub
      </a>
      <a
        href="#workflow"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-lg border border-[var(--border-color)] text-[var(--text-primary)] hover:bg-[var(--bg-primary)] font-semibold text-base transition-colors"
      >
        See how it works
      </a>
    </div>
  </div>
</section>
