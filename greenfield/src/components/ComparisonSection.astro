---
const withoutSpec = [
  'Specs live in Notion / Google Docs',
  'AI agents guess at requirements',
  'Features drift from original intent',
  'Rework discovered late in development',
  'Every team member has a different mental model',
];

const withSpec = [
  'Specs live in git alongside code',
  'AI agents implement from verified stories',
  'Every feature maps to a living spec',
  'Acceptance criteria catch drift immediately',
  'One truth, accessible to everyone',
];
---
<section data-test="comparison-section" id="comparison" style="padding: 5rem 1.5rem; background-color: var(--color-surface);">
  <div style="max-width: 1000px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 3rem;">
      <h2 style="font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; margin: 0 0 0.75rem; color: var(--color-text);">
        With vs. Without RootSpec
      </h2>
      <p style="color: var(--color-text-muted); font-size: 1.1rem; max-width: 540px; margin: 0 auto;">
        The difference between building on shifting sand and building on a foundation.
      </p>
    </div>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
      <div
        data-test="comparison-without"
        style="
          background: rgba(239,68,68,0.05);
          border: 1px solid rgba(239,68,68,0.25);
          border-radius: 0.75rem;
          padding: 1.75rem;
        "
      >
        <h3 style="font-size: 1rem; font-weight: 700; margin: 0 0 1.25rem; color: #f87171; display: flex; align-items: center; gap: 0.5rem;">
          <span>✗</span> Without RootSpec
        </h3>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem;">
          {withoutSpec.map(item => (
            <li style="display: flex; align-items: flex-start; gap: 0.625rem; font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.45;">
              <span style="color: #f87171; flex-shrink: 0; margin-top: 0.1rem;">✗</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div
        data-test="comparison-with"
        style="
          background: rgba(34,197,94,0.05);
          border: 1px solid rgba(34,197,94,0.25);
          border-radius: 0.75rem;
          padding: 1.75rem;
        "
      >
        <h3 style="font-size: 1rem; font-weight: 700; margin: 0 0 1.25rem; color: #4ade80; display: flex; align-items: center; gap: 0.5rem;">
          <span>✓</span> With RootSpec
        </h3>
        <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.75rem;">
          {withSpec.map(item => (
            <li style="display: flex; align-items: flex-start; gap: 0.625rem; font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.45;">
              <span style="color: #4ade80; flex-shrink: 0; margin-top: 0.1rem;">✓</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
