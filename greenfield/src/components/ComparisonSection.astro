---
const withoutSpec = [
  'Requirements live in Slack threads',
  'Engineers make assumptions to fill gaps',
  'Stakeholders review after code is written',
  'Rework costs spike near launch',
  'Tests are written after the fact — if at all',
];

const withSpec = [
  'L1–L5 hierarchy is the single source of truth',
  'Acceptance criteria are defined before coding',
  'AI agents implement features from the spec directly',
  'Tests are auto-generated from user stories',
  'Validation runs continuously against live code',
];
---
<section
  data-test="comparison-section"
  id="comparison"
  class="py-20 px-4"
  style="background-color: var(--color-bg);"
>
  <div class="section-container">
    <h2 class="text-3xl font-bold text-center mb-4" style="color: var(--color-text);">
      With and without a spec
    </h2>
    <p class="text-center text-lg mb-12 max-w-2xl mx-auto" style="color: var(--color-text-muted);">
      The difference isn't just process — it's outcomes.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Without spec -->
      <div
        data-test="comparison-without"
        class="rounded-xl p-8"
        style="background-color: var(--color-card-bg); border: 1px solid #ef444433;"
      >
        <div class="flex items-center gap-3 mb-6">
          <span class="text-2xl">❌</span>
          <h3 class="text-xl font-bold" style="color: #ef4444;">Without a spec</h3>
        </div>
        <ul class="flex flex-col gap-3">
          {withoutSpec.map((item) => (
            <li class="flex items-start gap-3 text-sm" style="color: var(--color-text-muted);">
              <span class="mt-0.5 shrink-0" style="color: #ef4444;">✗</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
      <!-- With spec -->
      <div
        data-test="comparison-with"
        class="rounded-xl p-8"
        style="background-color: var(--color-card-bg); border: 1px solid #22c55e33;"
      >
        <div class="flex items-center gap-3 mb-6">
          <span class="text-2xl">✅</span>
          <h3 class="text-xl font-bold" style="color: #22c55e;">With RootSpec</h3>
        </div>
        <ul class="flex flex-col gap-3">
          {withSpec.map((item) => (
            <li class="flex items-start gap-3 text-sm" style="color: var(--color-text-muted);">
              <span class="mt-0.5 shrink-0" style="color: #22c55e;">✓</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
