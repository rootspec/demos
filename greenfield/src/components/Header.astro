---
import rootspecConfig from '../../.rootspec.json';
const version = rootspecConfig.version;
---

<header style="background-color: var(--color-bg); border-bottom: 1px solid var(--color-border);">
  <div style="max-width: 1100px; margin: 0 auto; padding: 0.75rem 1.5rem; display: flex; align-items: center; justify-content: space-between;">
    <a href="/demos/greenfield/" style="font-family: 'JetBrains Mono', monospace; font-weight: 500; font-size: 1rem; color: var(--color-text-primary); text-decoration: none;">
      RootSpec
    </a>
    <nav style="display: flex; align-items: center; gap: 1.5rem;">
      <a href="#problem" style="font-size: 0.875rem; color: var(--color-text-secondary); text-decoration: none;">Problem</a>
      <a href="#explorer" style="font-size: 0.875rem; color: var(--color-text-secondary); text-decoration: none;">Explore</a>
      <a href="#wizard" style="font-size: 0.875rem; color: var(--color-text-secondary); text-decoration: none;">Try It</a>
      <a href="#notes" style="font-size: 0.875rem; color: var(--color-text-secondary); text-decoration: none;">Notes</a>
      <button
        id="theme-toggle"
        data-test="theme-toggle"
        aria-label="Toggle theme"
        style="background: none; border: 1px solid var(--color-border); border-radius: 4px; cursor: pointer; padding: 0.35rem 0.6rem; color: var(--color-text-secondary); font-size: 0.875rem; display: flex; align-items: center; gap: 0.25rem;"
      >
        <span id="theme-icon">☀</span>
      </button>
    </nav>
  </div>
</header>

<script is:inline>
  (function() {
    function applyTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      var icon = document.getElementById('theme-icon');
      if (icon) icon.textContent = theme === 'dark' ? '☽' : '☀';
    }
    var current = document.documentElement.getAttribute('data-theme') || 'light';
    var icon = document.getElementById('theme-icon');
    if (icon) icon.textContent = current === 'dark' ? '☽' : '☀';
    var btn = document.getElementById('theme-toggle');
    if (btn) {
      btn.addEventListener('click', function() {
        var next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        applyTheme(next);
        localStorage.setItem('rootspec-theme', next);
      });
    }
  })();
</script>
