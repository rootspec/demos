---
import { version } from '../../.rootspec.json';
---
<header style="border-bottom:1px solid var(--color-border);padding:1rem 1.5rem;font-family:'Inter',sans-serif;">
  <div style="max-width:860px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;">
    <span style="font-weight:600;font-size:0.9rem;letter-spacing:-0.01em;color:var(--color-text);">RootSpec</span>
    <div style="display:flex;align-items:center;gap:1rem;">
      <span data-test="version-badge" style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:var(--color-text-muted);background:var(--color-surface);padding:0.2rem 0.5rem;border-radius:3px;">v{version}</span>
      <button
        data-test="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle theme"
        style="background:none;border:1px solid var(--color-border);border-radius:4px;padding:0.3rem 0.6rem;cursor:pointer;font-size:0.8rem;color:var(--color-text-muted);font-family:'Inter',sans-serif;transition:border-color 150ms ease-out;"
      >
        <span id="theme-icon">☀</span>
      </button>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  const icon = document.getElementById('theme-icon');

  function getTheme() {
    return document.documentElement.getAttribute('data-theme') || 'light';
  }

  function updateIcon() {
    if (icon) icon.textContent = getTheme() === 'dark' ? '☽' : '☀';
  }

  updateIcon();

  btn?.addEventListener('click', () => {
    const next = getTheme() === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem('theme', next); } catch(e) {}
    updateIcon();
  });
</script>
