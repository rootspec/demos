---
import ThemeToggle from './ThemeToggle.tsx';
import { ROOTSPEC_VERSION } from '../data/config';
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/95 backdrop-blur supports-[backdrop-filter]:bg-[var(--color-bg)]/60">
  <div class="max-w-content mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <span class="font-mono font-bold text-lg">RootSpec</span>
      <span data-test="version-badge" class="font-mono text-xs px-2 py-0.5 rounded-full bg-[var(--color-bg-elevated)] text-[var(--color-text-secondary)]">
        v{ROOTSPEC_VERSION}
      </span>
    </div>
    <nav class="hidden sm:flex items-center gap-6 text-sm text-[var(--color-text-secondary)]">
      <a href="#problem" class="hover:text-[var(--color-text)] transition-colors">Problem</a>
      <a href="#how-it-works" class="hover:text-[var(--color-text)] transition-colors">How It Works</a>
      <a href="#explore" class="hover:text-[var(--color-text)] transition-colors">Explore</a>
      <a href="#get-started" class="hover:text-[var(--color-text)] transition-colors">Get Started</a>
    </nav>
    <ThemeToggle client:load />
  </div>
</header>
