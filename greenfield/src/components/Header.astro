---
---

<header class="sticky top-0 z-50 w-full border-b border-white/10 bg-[var(--bg-primary)]/90 backdrop-blur-sm">
  <div class="mx-auto max-w-6xl px-4 py-3 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="font-mono font-bold text-lg text-accent-400">/rootspec</span>
    </div>
    <nav class="flex items-center gap-4">
      <button
        data-test="theme-toggle"
        id="theme-toggle"
        class="p-2 rounded-lg hover:bg-white/10 transition-colors text-[var(--text-secondary)] hover:text-[var(--text-primary)]"
        aria-label="Toggle theme"
      >
        <svg id="theme-icon-dark" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 5a7 7 0 000 14 7 7 0 000-14z" />
        </svg>
        <svg id="theme-icon-light" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  const iconDark = document.getElementById('theme-icon-dark');
  const iconLight = document.getElementById('theme-icon-light');
  const html = document.documentElement;

  function updateIcons() {
    const isLight = html.classList.contains('light');
    iconDark?.classList.toggle('hidden', isLight);
    iconLight?.classList.toggle('hidden', !isLight);
  }

  updateIcons();

  btn?.addEventListener('click', () => {
    const isLight = html.classList.contains('light');
    if (isLight) {
      html.classList.remove('light');
      html.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    } else {
      html.classList.remove('dark');
      html.classList.add('light');
      localStorage.setItem('theme', 'light');
    }
    updateIcons();
  });
</script>
