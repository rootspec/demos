---
import SpecWizard from './SpecWizard.tsx';
---

<section
  style="padding: 4rem 1.5rem; border-top: 1px solid var(--color-border);"
>
  <div style="max-width: 72rem; margin: 0 auto;">
    <h2 style="font-family: Georgia, serif; font-size: clamp(1.375rem, 3vw, 2rem); font-weight: 400; color: var(--color-text-primary); margin-bottom: 0.75rem;">
      Spec your idea
    </h2>
    <p style="font-family: system-ui, sans-serif; font-size: 0.9375rem; color: var(--color-text-secondary); margin-bottom: 0.5rem; max-width: 40rem;">
      Walk through three steps and get a skeleton spec for your product idea.
      Output is template-based — no AI, no API calls, no data sent anywhere.
    </p>
    <p style="font-family: system-ui, sans-serif; font-size: 0.8125rem; color: var(--color-text-secondary); margin-bottom: 2.5rem; font-style: italic;">
      This shows the methodology is approachable, not academic.
    </p>
    <SpecWizard client:load />
  </div>
</section>
