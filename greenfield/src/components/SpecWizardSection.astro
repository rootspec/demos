---
import SpecWizard from './SpecWizard.tsx';
---
<section id="spec-wizard" class="py-16 px-6 max-w-4xl mx-auto">
  <div class="border-t pt-16" style="border-color: var(--color-border);">
    <h2 class="font-sans text-sm font-medium uppercase tracking-wider mb-4" style="color: var(--color-text-muted);">
      Spec Your Idea
    </h2>
    <p class="font-serif text-lg mb-8 max-w-2xl" style="color: var(--color-text);">
      Walk through a three-step process to produce a skeleton spec for your product idea. No AI calls — client-side templates.
    </p>
    <div class="max-w-2xl">
      <SpecWizard client:load />
    </div>
  </div>
</section>
