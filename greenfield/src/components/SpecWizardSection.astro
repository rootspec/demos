---
import SpecWizard from './SpecWizard.tsx';
---
<section id="try-it" style="padding:5rem 1.5rem;background:var(--color-surface);">
  <div style="max-width:48rem;margin:0 auto;">
    <h2 style="font-size:clamp(1.5rem,4vw,2.25rem);font-weight:700;margin:0 0 0.75rem;color:var(--color-text);">Try It</h2>
    <p style="font-size:1.05rem;color:var(--color-text-muted);margin:0 0 2rem;line-height:1.65;">See how RootSpec turns a product idea into a structured spec skeleton.</p>
    <SpecWizard client:load />
  </div>
</section>
