---
import SpecWizard from './SpecWizard.tsx';
---

<section id="wizard" class="py-24 px-4">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold mb-4">Try the Spec Wizard</h2>
      <p class="text-[var(--text-secondary)] text-lg max-w-2xl mx-auto">
        Enter your product idea and we'll generate a skeleton spec you can take into <code class="font-mono text-brand-primary">/rs-spec</code>.
      </p>
    </div>
    <SpecWizard client:load />
  </div>
</section>
