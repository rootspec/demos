---
import SpecWizard from './SpecWizard.astro';
---
<section
  id="spec-wizard"
  class="py-20 px-4"
  style="background-color: var(--color-surface);"
>
  <div class="section-container">
    <h2 class="text-3xl font-bold text-center mb-4" style="color: var(--color-text);">
      Try the spec wizard
    </h2>
    <p class="text-center text-lg mb-12 max-w-2xl mx-auto" style="color: var(--color-text-muted);">
      Generate a skeleton spec in 60 seconds. Enter your product idea and we'll build out L1–L3.
    </p>
    <SpecWizard />
  </div>
</section>
