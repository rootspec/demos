---
import SpecWizard from './SpecWizard.tsx';
---

<section id="wizard" style="padding: var(--space-2xl) 1.5rem; background-color: var(--color-surface); border-top: 1px solid var(--color-border);">
  <div style="max-width: 780px; margin: 0 auto;">
    <h2 style="font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-text-secondary); margin-bottom: 1.25rem;">
      Try It
    </h2>
    <h3 style="font-family: 'Source Serif 4', Georgia, serif; font-size: clamp(1.5rem, 3.5vw, 2.25rem); font-weight: 400; line-height: 1.25; color: var(--color-text-primary); margin-bottom: 0.75rem;">
      Spec your idea in four steps.
    </h3>
    <p style="font-family: 'Source Serif 4', Georgia, serif; font-size: 1rem; color: var(--color-text-secondary); line-height: 1.65; margin-bottom: 2rem;">
      Enter a product idea, walk through mission and pillars, and receive a skeleton L1–L3 spec. Client-side only — nothing leaves your browser.
    </p>
    <SpecWizard client:load />
  </div>
</section>
