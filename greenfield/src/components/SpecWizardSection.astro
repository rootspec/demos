---
import SpecWizard from './SpecWizard.tsx';
---
<section
  id="spec-wizard"
  class="w-full py-20 px-4"
  style="background-color:var(--surface);"
>
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center" style="color:var(--text);">
      Try the Spec Wizard
    </h2>
    <p class="text-center mb-12 text-lg" style="color:var(--text-muted);">
      Answer a few questions about your product and see a skeleton spec generated instantly.
    </p>
    <SpecWizard client:load />
  </div>
</section>
