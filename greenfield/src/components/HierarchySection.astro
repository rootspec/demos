---
import HierarchyExplorer from './HierarchyExplorer.tsx';
---

<section
  style="padding: 4rem 1.5rem; border-top: 1px solid var(--color-border);"
>
  <div style="max-width: 72rem; margin: 0 auto;">
    <h2 style="font-family: Georgia, serif; font-size: clamp(1.375rem, 3vw, 2rem); font-weight: 400; color: var(--color-text-primary); margin-bottom: 0.75rem;">
      The five-level hierarchy
    </h2>
    <p style="font-family: system-ui, sans-serif; font-size: 0.9375rem; color: var(--color-text-secondary); margin-bottom: 2.5rem; max-width: 40rem;">
      Each level can only reference higher levels, never lower. Click a level to explore its content.
    </p>
    <div style="max-width: 48rem;">
      <HierarchyExplorer client:load />
    </div>
  </div>
</section>
