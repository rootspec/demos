---
import HierarchyExplorer from './HierarchyExplorer.astro';
---
<section
  id="hierarchy"
  class="py-20 px-4"
  style="background-color: var(--color-surface);"
>
  <div class="section-container">
    <h2 class="text-3xl font-bold text-center mb-4" style="color: var(--color-text);">
      The five-level hierarchy
    </h2>
    <p class="text-center text-lg mb-12 max-w-2xl mx-auto" style="color: var(--color-text-muted);">
      RootSpec structures your product knowledge in five nested layers — from foundational philosophy
      down to testable user stories. Click any level to explore.
    </p>
    <HierarchyExplorer />
  </div>
</section>
