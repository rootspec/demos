---
import HierarchyExplorer from './HierarchyExplorer.tsx';
---
<section class="w-full py-20 px-4" style="background-color:var(--bg);">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 text-center" style="color:var(--text);">
      The Five-Level Specification Hierarchy
    </h2>
    <p class="text-center mb-12 text-lg" style="color:var(--text-muted);">
      Click any level to explore what it contains and how it feeds into the next.
    </p>
    <HierarchyExplorer client:load />
  </div>
</section>
