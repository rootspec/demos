---
import HierarchyExplorer from './HierarchyExplorer';
---

<section id="hierarchy" class="hierarchy-section">
  <div class="container">
    <div class="section-label">The Five Levels</div>
    <h2>A spec with five floors, not one</h2>
    <p class="section-desc">
      RootSpec organises every product decision into five levels — from immutable philosophy down to machine-readable tests. Click any level to explore.
    </p>
    <HierarchyExplorer client:load />
  </div>
</section>

<style>
  .hierarchy-section {
    background: var(--color-bg);
  }

  .hierarchy-section h2 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .section-desc {
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
    margin-bottom: 2.5rem;
    max-width: 560px;
  }

  :global(.hierarchy-explorer) {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  :global(.level-item) {
    border: 1px solid var(--color-border);
    border-radius: 0.625rem;
    overflow: hidden;
    background: var(--color-bg);
    transition: border-color 0.15s ease;
  }

  :global(.level-item.level-expanded) {
    border-color: var(--color-accent);
  }

  :global(.level-header) {
    width: 100%;
    background: none;
    border: none;
    padding: 1rem 1.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-align: left;
    color: var(--color-text-primary);
    transition: background 0.1s ease;
  }

  :global(.level-header:hover) {
    background: var(--color-surface);
  }

  :global(.level-left) {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  :global(.level-num) {
    background: var(--color-accent);
    color: white;
    font-size: 0.6875rem;
    font-weight: 800;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-family: monospace;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  :global(.level-text) {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  :global(.level-name) {
    font-weight: 700;
    font-size: 1rem;
    line-height: 1.3;
  }

  :global(.level-tagline) {
    font-size: 0.8125rem;
    color: var(--color-text-secondary);
  }

  :global(.level-chevron) {
    font-size: 0.625rem;
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }

  :global(.level-content) {
    padding: 0 1.25rem 1.25rem;
    border-top: 1px solid var(--color-border);
  }

  :global(.level-description) {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    padding: 0.875rem 0 0.75rem;
    margin-bottom: 0.75rem;
  }

  :global(.level-example) {
    font-size: 0.8125rem;
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
  }
</style>
