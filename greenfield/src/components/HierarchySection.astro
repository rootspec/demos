---
import HierarchyExplorer from './HierarchyExplorer.tsx';
---
<section class="py-16 px-6 max-w-4xl mx-auto">
  <div class="border-t pt-16" style="border-color: var(--color-border);">
    <h2 class="font-sans text-sm font-medium uppercase tracking-wider mb-4" style="color: var(--color-text-muted);">
      The Hierarchy
    </h2>
    <p class="font-serif text-lg mb-8 max-w-2xl" style="color: var(--color-text);">
      RootSpec organizes intent into five levels. Each level can only reference higher levels — never lower.
      This makes philosophy stable when implementation changes.
    </p>
    <HierarchyExplorer client:load />
  </div>
</section>
