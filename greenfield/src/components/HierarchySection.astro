---
import HierarchyExplorer from './HierarchyExplorer.tsx';
---

<section class="py-20 px-4 bg-gray-50 dark:bg-gray-900">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        Five levels of structured clarity
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Every RootSpec spec is organized into five nested levels — from immutable principles to concrete test cases. Click any level to explore.
      </p>
    </div>
    <HierarchyExplorer client:load />
  </div>
</section>
