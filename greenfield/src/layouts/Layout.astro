---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'RootSpec — Build software from intent, not assumption' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="RootSpec is a structured specification methodology for building software from intent, not assumption." />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- Apply theme immediately to prevent flash -->
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('rootspec-theme');
      document.documentElement.setAttribute('data-theme', stored === 'dark' ? 'dark' : 'light');
    })();
  </script>
</head>
<body>
  <slot />
  <script is:inline>
    // Wire up the theme toggle after DOM is ready
    (function() {
      function applyTheme(theme) {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('rootspec-theme', theme);
        var iconSun = document.getElementById('icon-sun');
        var iconMoon = document.getElementById('icon-moon');
        if (iconSun && iconMoon) {
          iconSun.style.display = theme === 'dark' ? 'block' : 'none';
          iconMoon.style.display = theme === 'dark' ? 'none' : 'block';
        }
      }

      var stored = localStorage.getItem('rootspec-theme') || 'light';
      applyTheme(stored);

      var btn = document.getElementById('theme-toggle');
      if (btn) {
        btn.addEventListener('click', function() {
          var current = document.documentElement.getAttribute('data-theme') || 'light';
          applyTheme(current === 'dark' ? 'light' : 'dark');
        });
      }
    })();
  </script>
</body>
</html>
