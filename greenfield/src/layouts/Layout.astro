---
import Header from '../components/Header.astro';

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "RootSpec - Philosophy Guides Implementation",
  description = "RootSpec is a methodology that transforms product descriptions into testable, hierarchical specifications where philosophy guides implementation."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <slot />
  </body>
</html>

<style is:global>
  /* CSS Custom Properties */
  :root {
    /* Colors - Light Theme */
    --color-primary: #2563eb;
    --color-primary-hover: #1d4ed8;
    --color-primary-subtle: #dbeafe;
    --color-background: #ffffff;
    --color-surface-elevated: #f8fafc;
    --color-text: #1f2937;
    --color-text-secondary: #6b7280;
    --color-border: #e5e7eb;

    /* Typography */
    --text-xs: 0.75rem;
    --text-sm: 0.875rem;
    --text-base: 1rem;
    --text-lg: 1.125rem;
    --text-xl: 1.25rem;
    --text-2xl: 1.5rem;
    --text-3xl: 1.875rem;
    --text-4xl: 2.25rem;

    /* Spacing */
    --space-4: 4px;
    --space-8: 8px;
    --space-12: 12px;
    --space-16: 16px;
    --space-20: 20px;
    --space-24: 24px;
    --space-32: 32px;
    --space-48: 48px;
    --space-64: 64px;
  }

  /* Dark Theme */
  @media (prefers-color-scheme: dark) {
    :root {
      --color-primary: #3b82f6;
      --color-primary-hover: #2563eb;
      --color-primary-subtle: #1e3a8a;
      --color-background: #111827;
      --color-surface-elevated: #1f2937;
      --color-text: #f9fafb;
      --color-text-secondary: #9ca3af;
      --color-border: #374151;
    }
  }

  html.dark {
    --color-primary: #3b82f6;
    --color-primary-hover: #2563eb;
    --color-primary-subtle: #1e3a8a;
    --color-background: #111827;
    --color-surface-elevated: #1f2937;
    --color-text: #f9fafb;
    --color-text-secondary: #9ca3af;
    --color-border: #374151;
  }

  /* Base Styles */
  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    line-height: 1.6;
  }

  body {
    background-color: var(--color-background);
    color: var(--color-text);
    transition: background-color 200ms ease, color 200ms ease;
  }

  /* Reduce motion for accessibility */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }

  /* Interactive Components Styles */

  /* Hierarchy Explorer */
  .hierarchy-explorer {
    padding: var(--space-64) 0;
    background: var(--color-background);
  }

  .hierarchy-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-16);
  }

  .hierarchy-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    text-align: center;
    margin-bottom: var(--space-16);
    color: var(--color-text);
  }

  .hierarchy-intro {
    font-size: var(--text-lg);
    text-align: center;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-48);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .levels-container {
    position: relative;
  }

  .level {
    background: var(--color-surface-elevated);
    border: 2px solid var(--color-border);
    border-radius: 12px;
    margin-bottom: var(--space-16);
    cursor: pointer;
    transition: all 300ms ease;
    position: relative;
  }

  .level:hover,
  .level:focus {
    border-color: var(--color-primary);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
    outline: none;
  }

  .level.highlighted {
    background: var(--color-primary-subtle);
    border-color: var(--color-primary);
  }

  .level-header {
    display: flex;
    align-items: center;
    padding: var(--space-20);
    gap: var(--space-16);
  }

  .level-number {
    background: var(--color-primary);
    color: white;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    flex-shrink: 0;
  }

  .level-name {
    flex: 1;
    margin: 0;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
  }

  .expand-icon {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    transition: transform 300ms ease;
  }

  .level.expanded .expand-icon {
    transform: rotate(180deg);
  }

  .level-content {
    padding: 0 var(--space-20) var(--space-20);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-20);
  }

  .level-description {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-16);
  }

  .level-examples h4,
  .level-references h4 {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text);
    margin-bottom: var(--space-8);
  }

  .level-examples ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .level-examples li {
    background: var(--color-background);
    padding: var(--space-8) var(--space-12);
    border-radius: 6px;
    margin-bottom: var(--space-4);
    border-left: 3px solid var(--color-primary);
    color: var(--color-text-secondary);
  }

  .reference-pills {
    display: flex;
    gap: var(--space-8);
    flex-wrap: wrap;
  }

  .reference-pill {
    background: var(--color-primary);
    color: white;
    padding: var(--space-4) var(--space-8);
    border-radius: 100px;
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .reference-arrows {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: var(--color-background);
    padding: var(--space-16);
    border-radius: 8px;
    border: 2px solid var(--color-primary);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    z-index: 10;
  }

  .arrow-explanation {
    font-size: var(--text-sm);
    color: var(--color-text);
    text-align: center;
  }

  /* Spec Wizard */
  .spec-wizard {
    padding: var(--space-64) 0;
    background: var(--color-surface-elevated);
  }

  .wizard-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--space-16);
  }

  .wizard-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    text-align: center;
    margin-bottom: var(--space-16);
    color: var(--color-text);
  }

  .wizard-intro {
    font-size: var(--text-lg);
    text-align: center;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-32);
    line-height: 1.6;
  }

  .start-wizard-btn {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: var(--space-16) var(--space-32);
    border-radius: 8px;
    font-size: var(--text-lg);
    font-weight: 600;
    cursor: pointer;
    transition: background-color 200ms ease;
    display: block;
    margin: 0 auto;
  }

  .start-wizard-btn:hover {
    background: var(--color-primary-hover);
  }

  .wizard-progress {
    margin-bottom: var(--space-32);
  }

  .progress-steps {
    display: flex;
    justify-content: center;
    gap: var(--space-24);
    margin-bottom: var(--space-16);
  }

  .progress-step {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-border);
    color: var(--color-text-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    transition: all 200ms ease;
  }

  .progress-step.active {
    background: var(--color-primary);
    color: white;
  }

  .progress-bar {
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-primary);
    transition: width 300ms ease;
  }

  .wizard-step {
    background: var(--color-background);
    border-radius: 12px;
    padding: var(--space-32);
    border: 1px solid var(--color-border);
  }

  .step-title {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-12);
    color: var(--color-text);
  }

  .step-description {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-24);
  }

  .mission-templates {
    display: grid;
    gap: var(--space-12);
    margin-bottom: var(--space-24);
  }

  .mission-template {
    background: var(--color-surface-elevated);
    border: 2px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-16);
    cursor: pointer;
    transition: all 200ms ease;
    text-align: left;
    font-size: var(--text-base);
    line-height: 1.5;
  }

  .mission-template:hover {
    border-color: var(--color-primary);
  }

  .mission-template.selected {
    background: var(--color-primary-subtle);
    border-color: var(--color-primary);
  }

  .custom-mission {
    margin-bottom: var(--space-24);
  }

  .custom-mission label {
    display: block;
    margin-bottom: var(--space-8);
    font-weight: 600;
    color: var(--color-text);
  }

  .custom-mission-input {
    width: 100%;
    min-height: 80px;
    padding: var(--space-12);
    border: 2px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-background);
    color: var(--color-text);
    font-size: var(--text-base);
    line-height: 1.5;
    resize: vertical;
  }

  .custom-mission-input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-12);
    margin-bottom: var(--space-24);
  }

  .pillar-option {
    background: var(--color-surface-elevated);
    border: 2px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-12);
    cursor: pointer;
    transition: all 200ms ease;
    text-align: center;
    font-size: var(--text-sm);
  }

  .pillar-option:hover {
    border-color: var(--color-primary);
  }

  .pillar-option.selected {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .selected-pillars {
    margin-bottom: var(--space-24);
  }

  .selected-pillars h4 {
    margin-bottom: var(--space-12);
    color: var(--color-text);
  }

  .pillars-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
  }

  .selected-pillar {
    background: var(--color-primary-subtle);
    color: var(--color-primary);
    padding: var(--space-4) var(--space-8);
    border-radius: 100px;
    font-size: var(--text-xs);
    font-weight: 600;
  }

  .interaction-input label {
    display: block;
    margin-bottom: var(--space-8);
    font-weight: 600;
    color: var(--color-text);
  }

  .interaction-textarea {
    width: 100%;
    min-height: 100px;
    padding: var(--space-12);
    border: 2px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-background);
    color: var(--color-text);
    font-size: var(--text-base);
    line-height: 1.5;
    margin-bottom: var(--space-24);
    resize: vertical;
  }

  .interaction-textarea:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .next-step-btn,
  .complete-wizard-btn {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: var(--space-12) var(--space-24);
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 200ms ease;
  }

  .next-step-btn:hover,
  .complete-wizard-btn:hover {
    background: var(--color-primary-hover);
  }

  .spec-output {
    background: var(--color-background);
    border-radius: 12px;
    padding: var(--space-32);
    border: 1px solid var(--color-border);
  }

  .output-title {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-24);
    color: var(--color-text);
    text-align: center;
  }

  .spec-levels {
    display: grid;
    gap: var(--space-20);
    margin-bottom: var(--space-24);
  }

  .spec-level {
    background: var(--color-surface-elevated);
    border-radius: 8px;
    padding: var(--space-16);
    border-left: 4px solid var(--color-primary);
  }

  .spec-level-title {
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-8);
    color: var(--color-primary);
  }

  .spec-level ul {
    margin: 0;
    padding-left: var(--space-20);
  }

  .spec-level li {
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: var(--space-4);
  }

  .restart-wizard-btn {
    background: transparent;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
    padding: var(--space-12) var(--space-24);
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: all 200ms ease;
    display: block;
    margin: 0 auto;
  }

  .restart-wizard-btn:hover {
    background: var(--color-primary);
    color: white;
  }

  /* Comparison */
  .comparison {
    padding: var(--space-64) 0;
    background: var(--color-background);
  }

  .comparison-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-16);
  }

  .comparison-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    text-align: center;
    margin-bottom: var(--space-16);
    color: var(--color-text);
  }

  .comparison-intro {
    font-size: var(--text-lg);
    text-align: center;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-32);
  }

  .comparison-controls {
    text-align: center;
    margin-bottom: var(--space-32);
  }

  .comparison-toggle {
    background: var(--color-primary);
    color: white;
    border: none;
    padding: var(--space-12) var(--space-24);
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 200ms ease;
  }

  .comparison-toggle:hover {
    background: var(--color-primary-hover);
  }

  .comparison-content {
    position: relative;
    min-height: 400px;
  }

  .comparison-panel {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    opacity: 0;
    transform: translateX(20px);
    transition: all 300ms ease;
    pointer-events: none;
  }

  .comparison-panel.active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }

  .panel-title {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-16);
    color: var(--color-text);
    text-align: center;
  }

  .panel-content {
    background: var(--color-surface-elevated);
    border-radius: 12px;
    padding: var(--space-24);
    border: 1px solid var(--color-border);
  }

  .spec-example h4 {
    margin-bottom: var(--space-16);
    color: var(--color-text);
  }

  .chaotic-spec,
  .structured-spec {
    background: var(--color-background);
    padding: var(--space-20);
    border-radius: 8px;
    margin-bottom: var(--space-16);
  }

  .chaotic-spec p,
  .chaotic-spec em {
    margin-bottom: var(--space-12);
    color: var(--color-text-secondary);
  }

  .chaotic-spec ul {
    list-style: none;
    padding: 0;
    margin-bottom: var(--space-16);
  }

  .chaotic-spec li {
    padding: var(--space-8);
    margin-bottom: var(--space-4);
    background: rgba(239, 68, 68, 0.1);
    border-left: 3px solid #dc2626;
    border-radius: 4px;
    font-style: italic;
  }

  .spec-level {
    margin-bottom: var(--space-12);
    padding: var(--space-12);
    background: var(--color-surface-elevated);
    border-radius: 6px;
    border-left: 3px solid var(--color-primary);
  }

  .spec-level h5 {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: var(--space-8);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .spec-level p {
    margin: 0;
    color: var(--color-text);
    font-weight: 500;
  }

  .spec-level ul {
    margin: 0;
    padding-left: var(--space-16);
  }

  .spec-level li {
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .problem-indicators,
  .success-indicators {
    display: grid;
    gap: var(--space-8);
  }

  .problem,
  .success {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    padding: var(--space-8) var(--space-12);
    border-radius: 6px;
    font-size: var(--text-sm);
  }

  .problem {
    background: rgba(239, 68, 68, 0.1);
    color: #dc2626;
  }

  .success {
    background: rgba(34, 197, 94, 0.1);
    color: #16a34a;
  }

  .comparison-summary {
    text-align: center;
    margin-top: var(--space-32);
    padding: var(--space-24);
    background: var(--color-surface-elevated);
    border-radius: 12px;
    border: 2px solid var(--color-primary-subtle);
  }

  .comparison-summary p {
    margin: 0;
    font-size: var(--text-lg);
    color: var(--color-text);
    line-height: 1.6;
  }

  .comparison-summary em {
    color: var(--color-primary);
    font-style: normal;
    font-weight: 600;
  }

  /* Mobile responsiveness */
  @media (max-width: 768px) {
    .hierarchy-explorer,
    .spec-wizard,
    .comparison {
      padding: var(--space-48) 0;
    }

    .levels-container {
      margin-bottom: var(--space-24);
    }

    .reference-arrows {
      position: fixed;
      top: 50%;
      left: 50%;
      right: var(--space-16);
      transform: translate(-50%, -50%);
    }

    .pillars-grid {
      grid-template-columns: 1fr;
    }

    .progress-steps {
      gap: var(--space-16);
    }

    .comparison-panel {
      position: relative;
      margin-bottom: var(--space-24);
    }

    .comparison-content {
      min-height: auto;
    }
  }
</style>