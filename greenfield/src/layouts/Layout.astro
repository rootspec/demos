---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'RootSpec — Spec-driven AI development',
  description = 'A specification methodology where philosophy guides implementation, never vice versa.',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Prevent flash of wrong theme: read localStorage before first paint -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('rootspec-theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
