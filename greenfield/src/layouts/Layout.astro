---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'RootSpec — Spec-first software development' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="RootSpec: specification-driven development where philosophy guides implementation." />
    <title>{title}</title>
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('rootspec-theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
