---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "RootSpec - Structured specification methodology for software development" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <style>
    :root {
      --primary-blue: #2563eb;
      --text-dark: #1f2937;
      --text-light: #6b7280;
      --bg-light: #ffffff;
      --bg-gray: #f9fafb;
      --border-gray: #e5e7eb;
    }

    [data-theme="dark"] {
      --text-dark: #f9fafb;
      --text-light: #d1d5db;
      --bg-light: #111827;
      --bg-gray: #1f2937;
      --border-gray: #374151;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: system-ui, -apple-system, sans-serif;
      line-height: 1.6;
      color: var(--text-dark);
      background-color: var(--bg-light);
      transition: background-color 0.2s ease, color 0.2s ease;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1rem;
    }

    @media (min-width: 768px) {
      .container {
        padding: 0 2rem;
      }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>