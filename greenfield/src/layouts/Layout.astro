---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'RootSpec — Spec-first development methodology' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="RootSpec is a five-level specification methodology that transforms a sparse product description into a fully validated development spec." />
    <!-- Flash prevention: apply theme before first paint -->
    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('rootspec-theme');
          var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch(e) {}
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
