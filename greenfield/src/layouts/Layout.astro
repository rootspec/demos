---
import '../styles/global.css';
interface Props {
  title?: string;
}
const { title = 'RootSpec — Spec-First Development Framework' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="RootSpec is a specification methodology that lets you build products from structured specs, not intuition. This site was generated from a sparse seed using the RootSpec framework." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <script>
      // Apply theme before render to prevent flash
      (function() {
        const stored = localStorage.getItem('theme');
        const preferred = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        const theme = stored || preferred;
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <slot />
  </body>
</html>
