---
import '../styles/global.css';
import Header from '../components/Header.astro';

interface Props {
  title?: string;
}
const { title = 'RootSpec — Specification for the AI Age' } = Astro.props;
---
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="RootSpec is a structured specification methodology that keeps AI agents aligned with your product vision." />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
  </body>
</html>
